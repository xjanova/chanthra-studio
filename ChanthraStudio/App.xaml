<Application
    x:Class="ChanthraStudio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:ChanthraStudio.Helpers"
    xmlns:local="clr-namespace:ChanthraStudio"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml" />
                <ResourceDictionary Source="/Themes/Effects.xaml" />
                <ResourceDictionary Source="/Themes/Typography.xaml" />
                <ResourceDictionary Source="/Themes/Icons.xaml" />
                <ResourceDictionary Source="/Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <helpers:EnumEqualsConverter x:Key="EnumEquals" />
            <helpers:StringEqualsConverter x:Key="StringEquals" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
            <helpers:NotNullOrEmptyToVisibilityConverter x:Key="NotNullOrEmpty" />
            <helpers:ClipPathToImageConverter x:Key="ClipPathToImage" />
            <helpers:PercentToWidthConverter x:Key="PercentToWidth" />
            <helpers:StatusToBrushConverter x:Key="StatusToBrush" />
            <helpers:ResourceLookupConverter x:Key="ResourceLookup" />
            <helpers:MultiplyConverter x:Key="MultiplyConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
