<UserControl
    x:Class="ChanthraStudio.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:ChanthraStudio.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Height="28"
    d:DataContext="{d:DesignInstance vm:StatusBarViewModel}"
    d:DesignWidth="1640"
    mc:Ignorable="d">
    <Border
        Background="{StaticResource BrushBlackOverlay35}"
        BorderBrush="{StaticResource BrushLineHairline}"
        BorderThickness="0,1,0,0">
        <Grid Margin="14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Ellipse
                    Width="6"
                    Height="6"
                    Margin="0,0,6,0"
                    Style="{StaticResource PulsingOkDot}"
                    Effect="{StaticResource ShadowGoldGlowSoft}" />
                <TextBlock
                    Margin="0,0,14,0"
                    Style="{StaticResource TextMono}"
                    Text="{Binding ConnectionLabel}" />

                <!--  GPU name + utilisation bar  -->
                <TextBlock
                    Margin="0,0,8,0"
                    Style="{StaticResource TextMono}"
                    Text="{Binding GpuLabel}" />

                <c:Sparkline
                    Width="56"
                    Height="16"
                    Margin="0,0,6,0"
                    MaxValue="100"
                    Stroke="{StaticResource BrushGoldHi}"
                    Values="{Binding UtilHistory}" />
                <TextBlock
                    Margin="0,0,14,0"
                    Style="{StaticResource TextMono}"
                    Text="{Binding GpuUtilLabel}" />

                <!--  Temperature pill (color-coded)  -->
                <Border
                    Margin="0,0,10,0"
                    Padding="6,1"
                    VerticalAlignment="Center"
                    CornerRadius="99">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1F6DBF8C" />
                            <Setter Property="BorderBrush" Value="#666DBF8C" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TempKind}" Value="cool">
                                    <Setter Property="Background" Value="#1F6DBF8C" />
                                    <Setter Property="BorderBrush" Value="#666DBF8C" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TempKind}" Value="warm">
                                    <Setter Property="Background" Value="#1FE0B056" />
                                    <Setter Property="BorderBrush" Value="#66E0B056" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TempKind}" Value="hot">
                                    <Setter Property="Background" Value="#1FD05A5A" />
                                    <Setter Property="BorderBrush" Value="#66D05A5A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock
                        FontFamily="{StaticResource FontMono}"
                        FontSize="10"
                        Foreground="{StaticResource BrushText1}"
                        Text="{Binding TempLabel}" />
                </Border>

                <TextBlock
                    Margin="0,0,14,0"
                    Style="{StaticResource TextMono}"
                    Text="{Binding VramLabel}" />
                <TextBlock
                    Margin="0,0,14,0"
                    Style="{StaticResource TextMono}"
                    Text="{Binding PowerLabel}" />
                <TextBlock
                    Margin="0,0,14,0"
                    Style="{StaticResource TextMono}"
                    Foreground="{StaticResource BrushText3}"
                    Text="{Binding FanLabel, StringFormat=fan {0}}" />
                <TextBlock
                    Margin="0,0,14,0"
                    Style="{StaticResource TextMono}"
                    Text="{Binding QueueLabel}" />
            </StackPanel>

            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Border
                    Margin="0,0,14,0"
                    Padding="6,2"
                    VerticalAlignment="Center"
                    CornerRadius="99">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1FE0B056" />
                            <Setter Property="BorderBrush" Value="#66E0B056" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LicenseKind}" Value="ok">
                                    <Setter Property="Background" Value="#1F6DBF8C" />
                                    <Setter Property="BorderBrush" Value="#666DBF8C" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LicenseKind}" Value="warn">
                                    <Setter Property="Background" Value="#1FE0B056" />
                                    <Setter Property="BorderBrush" Value="#66E0B056" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LicenseKind}" Value="err">
                                    <Setter Property="Background" Value="#1FD05A5A" />
                                    <Setter Property="BorderBrush" Value="#66D05A5A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock
                        FontFamily="{StaticResource FontMono}"
                        FontSize="10"
                        Foreground="{StaticResource BrushText1}"
                        Text="{Binding LicenseLabel}" />
                </Border>
                <TextBlock
                    Margin="0,0,14,0"
                    Style="{StaticResource TextMono}"
                    Text="{Binding VersionLabel}" />
                <TextBlock Style="{StaticResource TextMono}" Text="{Binding AutosaveLabel}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
