<UserControl
    x:Class="ChanthraStudio.Views.NodeFlowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:m="clr-namespace:ChanthraStudio.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    d:DataContext="{d:DesignInstance vm:NodeFlowViewModel}"
    d:DesignHeight="940"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:NodeFlowViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>

        <!--  Wire colors keyed off the SocketType enum  -->
        <Style x:Key="WirePath" TargetType="Path">
            <Setter Property="StrokeThickness" Value="1.6" />
            <Setter Property="Stroke" Value="{StaticResource BrushGoldSoft}" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="Effect" Value="{StaticResource ShadowGoldGlowSoft}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Model">
                    <Setter Property="Stroke" Value="{StaticResource BrushGoldHi}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Clip">
                    <Setter Property="Stroke" Value="{StaticResource BrushMoon}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Vae">
                    <Setter Property="Stroke" Value="{StaticResource BrushPlumLight}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Latent">
                    <Setter Property="Stroke" Value="{StaticResource BrushCrimson}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Conditioning">
                    <Setter Property="Stroke" Value="{StaticResource BrushGold}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Image">
                    <Setter Property="Stroke" Value="{StaticResource BrushGoldHi}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Socket dot — small ellipse on the edge of a node  -->
        <Style x:Key="SocketDot" TargetType="Ellipse">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Setter Property="Fill" Value="{StaticResource BrushGoldHi}" />
            <Setter Property="Stroke" Value="{StaticResource BrushVoid}" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="Effect" Value="{StaticResource ShadowGoldGlowSoft}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Model">
                    <Setter Property="Fill" Value="{StaticResource BrushGoldHi}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Clip">
                    <Setter Property="Fill" Value="{StaticResource BrushMoon}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Vae">
                    <Setter Property="Fill" Value="{StaticResource BrushPlumLight}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Latent">
                    <Setter Property="Fill" Value="{StaticResource BrushCrimson}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Conditioning">
                    <Setter Property="Fill" Value="{StaticResource BrushGold}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Image">
                    <Setter Property="Fill" Value="{StaticResource BrushGoldHi}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Node card body  -->
        <Style x:Key="NodeCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushBgElevated}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushLineHairline}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Effect" Value="{StaticResource ShadowCardRest}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BrushGoldHi}" />
                    <Setter Property="Effect" Value="{StaticResource ShadowGoldGlowSoft}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Palette item button (left rail)  -->
        <Style x:Key="PaletteItem" TargetType="Button" BasedOn="{StaticResource ButtonPill}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontFamily" Value="{StaticResource FontUI}" />
            <Setter Property="FontSize" Value="11.5" />
        </Style>

        <!--  Mini scrollbar reuse  -->
        <Style BasedOn="{StaticResource ThinScrollBar}" TargetType="ScrollBar" />

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!--  ═══════════ LEFT PALETTE ═══════════  -->
        <Border
            Grid.Column="0"
            Background="{StaticResource BrushSurface02}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14,16,14,12">
                    <TextBlock
                        FontFamily="{StaticResource FontDisplay}"
                        FontSize="18"
                        FontStyle="Italic"
                        Foreground="{StaticResource BrushGoldHi}"
                        Text="Node Flow" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontFamily="{StaticResource FontMono}"
                        FontSize="10"
                        Foreground="{StaticResource BrushText3}"
                        Text="visual graph editor · ComfyUI compat" />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    Margin="12,0,12,12"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="9"
                            Foreground="{StaticResource BrushText4}"
                            Text="LOADERS" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="LoadCheckpoint"
                            Content="◆  Load Checkpoint"
                            Style="{StaticResource PaletteItem}" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="LoraLoader"
                            Content="◆  Load LoRA"
                            Style="{StaticResource PaletteItem}" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="LoadImage"
                            Content="◆  Load Image"
                            Style="{StaticResource PaletteItem}" />

                        <TextBlock
                            Margin="0,12,0,6"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="9"
                            Foreground="{StaticResource BrushText4}"
                            Text="CONDITIONING" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="CLIPTextEncode"
                            Content="✦  CLIP Text Encode"
                            Style="{StaticResource PaletteItem}" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="ControlNetApply"
                            Content="✦  ControlNet Apply"
                            Style="{StaticResource PaletteItem}" />

                        <TextBlock
                            Margin="0,12,0,6"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="9"
                            Foreground="{StaticResource BrushText4}"
                            Text="LATENT" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="EmptyLatentImage"
                            Content="❍  Empty Latent"
                            Style="{StaticResource PaletteItem}" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="KSampler"
                            Content="❍  K Sampler"
                            Style="{StaticResource PaletteItem}" />

                        <TextBlock
                            Margin="0,12,0,6"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="9"
                            Foreground="{StaticResource BrushText4}"
                            Text="OUTPUT" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="VAEDecode"
                            Content="◐  VAE Decode"
                            Style="{StaticResource PaletteItem}" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="SaveImage"
                            Content="◐  Save Image"
                            Style="{StaticResource PaletteItem}" />

                        <TextBlock
                            Margin="0,12,0,6"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="9"
                            Foreground="{StaticResource BrushText4}"
                            Text="VIDEO" />
                        <Button
                            Command="{Binding AddNodeCommand}"
                            CommandParameter="AnimateDiff"
                            Content="▶  AnimateDiff"
                            Style="{StaticResource PaletteItem}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!--  ═══════════ CENTER CANVAS ═══════════  -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Toolbar  -->
            <Border
                Grid.Row="0"
                Background="{StaticResource BrushSurface02}"
                BorderBrush="{StaticResource BrushLineHairline}"
                BorderThickness="0,0,0,1">
                <StackPanel Margin="14,8" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding AutoArrangeCommand}"
                        Content="✦ Auto-arrange"
                        Style="{StaticResource ButtonPill}" />
                    <TextBlock
                        Margin="14,0,8,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource FontMono}"
                        FontSize="10"
                        Foreground="{StaticResource BrushText3}"
                        Text="ZOOM" />
                    <Button
                        Width="28"
                        Margin="0,0,4,0"
                        Command="{Binding ZoomOutCommand}"
                        Content="−"
                        Style="{StaticResource ButtonPill}" />
                    <Border
                        Width="60"
                        VerticalAlignment="Center"
                        Background="{StaticResource BrushBgInset}"
                        CornerRadius="3">
                        <TextBlock
                            Padding="0,4"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="10"
                            Foreground="{StaticResource BrushText1}"
                            Text="{Binding Zoom, StringFormat={}{0:P0}}" />
                    </Border>
                    <Button
                        Width="28"
                        Margin="4,0,8,0"
                        Command="{Binding ZoomInCommand}"
                        Content="+"
                        Style="{StaticResource ButtonPill}" />
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding ZoomResetCommand}"
                        Content="reset"
                        Style="{StaticResource ButtonPill}" />
                </StackPanel>
            </Border>

            <!--  Canvas viewport  -->
            <Grid
                Grid.Row="1"
                Background="{StaticResource BrushBgInset}"
                ClipToBounds="True"
                MouseRightButtonDown="Viewport_MouseRightButtonDown"
                MouseRightButtonUp="Viewport_MouseRightButtonUp"
                MouseMove="Viewport_MouseMove"
                MouseWheel="Viewport_MouseWheel">
                <!--  Dot-grid background to anchor the canvas perception  -->
                <Rectangle>
                    <Rectangle.Fill>
                        <DrawingBrush
                            TileMode="Tile"
                            Viewport="0,0,24,24"
                            ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#22D4A76A">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry Center="12,12" RadiusX="0.8" RadiusY="0.8" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!--  Pan/zoom canvas — every node is positioned in canvas-space coords  -->
                <Canvas x:Name="WorldCanvas" Background="Transparent">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                            <TranslateTransform X="{Binding PanX}" Y="{Binding PanY}" />
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!--  Wires — drawn first so they sit underneath the nodes  -->
                    <ItemsControl ItemsSource="{Binding Wires}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:FlowWire}">
                                <Path Data="{Binding Geometry}" Style="{StaticResource WirePath}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Nodes  -->
                    <ItemsControl ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:FlowNode}">
                                <Border
                                    MouseLeftButtonDown="Node_MouseLeftButtonDown"
                                    Style="{StaticResource NodeCard}"
                                    Width="{Binding Width}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  Header (drag handle)  -->
                                        <Border
                                            Grid.Row="0"
                                            Height="32"
                                            Background="{Binding AccentKey, Converter={StaticResource ResourceLookup}}"
                                            CornerRadius="9,9,0,0"
                                            Cursor="SizeAll">
                                            <Grid Margin="12,0">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource FontDisplay}"
                                                    FontSize="13"
                                                    FontStyle="Italic"
                                                    Foreground="#FF1A0D05"
                                                    Text="{Binding Title}" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource FontMono}"
                                                    FontSize="9"
                                                    Foreground="#992A1B3D"
                                                    Text="{Binding Id}" />
                                            </Grid>
                                        </Border>

                                        <!--  Sockets row (inputs left, outputs right)  -->
                                        <Grid Grid.Row="1" Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!--  Inputs  -->
                                            <ItemsControl Grid.Column="0" ItemsSource="{Binding Inputs}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type m:NodeSocket}">
                                                        <Grid Height="24">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse
                                                                Grid.Column="0"
                                                                Margin="-4,0,8,0"
                                                                VerticalAlignment="Center"
                                                                Style="{StaticResource SocketDot}" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                FontFamily="{StaticResource FontMono}"
                                                                FontSize="10"
                                                                Foreground="{StaticResource BrushText2}"
                                                                Text="{Binding Label}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!--  Outputs  -->
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Outputs}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type m:NodeSocket}">
                                                        <Grid Height="24">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                Grid.Column="0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                FontFamily="{StaticResource FontMono}"
                                                                FontSize="10"
                                                                Foreground="{StaticResource BrushText1}"
                                                                Text="{Binding Label}" />
                                                            <Ellipse
                                                                Grid.Column="1"
                                                                Margin="8,0,-4,0"
                                                                VerticalAlignment="Center"
                                                                Style="{StaticResource SocketDot}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>

                                        <!--  Params block  -->
                                        <ItemsControl Grid.Row="2" Margin="10,4,10,8" ItemsSource="{Binding Params}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type m:NodeParam}">
                                                    <Border
                                                        Margin="0,3,0,0"
                                                        Padding="6,3"
                                                        Background="{StaticResource BrushBgInset}"
                                                        CornerRadius="3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="80" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                Grid.Column="0"
                                                                FontFamily="{StaticResource FontMono}"
                                                                FontSize="9.5"
                                                                Foreground="{StaticResource BrushText3}"
                                                                Text="{Binding Label}" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                FontFamily="{StaticResource FontMono}"
                                                                FontSize="9.5"
                                                                Foreground="{StaticResource BrushText1}"
                                                                Text="{Binding Value}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </Grid>
        </Grid>

        <!--  ═══════════ RIGHT INSPECTOR + MINIMAP ═══════════  -->
        <Border
            Grid.Column="2"
            Background="{StaticResource BrushSurface02}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="160" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14,16,14,8">
                    <TextBlock
                        FontFamily="{StaticResource FontMono}"
                        FontSize="9"
                        Foreground="{StaticResource BrushText4}"
                        Text="INSPECTOR" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontFamily="{StaticResource FontDisplay}"
                        FontSize="14"
                        FontStyle="Italic"
                        Foreground="{StaticResource BrushText1}"
                        Text="{Binding SelectedTitle}" />
                </StackPanel>

                <!--  Mini-map  -->
                <Border
                    Grid.Row="1"
                    Margin="14,4,14,8"
                    Background="{StaticResource BrushBgInset}"
                    BorderBrush="{StaticResource BrushLineHairline}"
                    BorderThickness="1"
                    CornerRadius="6"
                    ClipToBounds="True">
                    <Canvas x:Name="MinimapCanvas">
                        <ItemsControl ItemsSource="{Binding Nodes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <!--  Map canvas-space (~1500 wide) into the minimap (~250 wide) — multiply by 0.16  -->
                                    <Setter Property="Canvas.Left" Value="{Binding X, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.16}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.16}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:FlowNode}">
                                    <Border
                                        Width="36"
                                        Height="14"
                                        Background="{Binding AccentKey, Converter={StaticResource ResourceLookup}}"
                                        BorderBrush="{StaticResource BrushVoid}"
                                        BorderThickness="0.5"
                                        CornerRadius="2"
                                        Opacity="0.85" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Border>

                <!--  Selected node properties  -->
                <ScrollViewer
                    Grid.Row="2"
                    Margin="14,0,14,14"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="9"
                            Foreground="{StaticResource BrushText4}"
                            Text="PARAMETERS" />
                        <ItemsControl ItemsSource="{Binding Selected.Params}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:NodeParam}">
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock
                                            FontFamily="{StaticResource FontMono}"
                                            FontSize="10"
                                            Foreground="{StaticResource BrushText3}"
                                            Text="{Binding Label}" />
                                        <Border
                                            Margin="0,3,0,0"
                                            Background="{StaticResource BrushBgInset}"
                                            BorderBrush="{StaticResource BrushLineHairline}"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                            <TextBox
                                                Padding="6,4"
                                                FontFamily="{StaticResource FontMono}"
                                                FontSize="10"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{StaticResource BrushText1}"
                                                Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                AcceptsReturn="True"
                                                TextWrapping="Wrap"
                                                MaxHeight="120" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border
                            Margin="0,8,0,0"
                            Padding="10,8"
                            Background="{StaticResource BrushBgInset}"
                            CornerRadius="6">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="{StaticResource FontMono}"
                                    FontSize="9"
                                    Foreground="{StaticResource BrushText4}"
                                    Text="HINT" />
                                <TextBlock
                                    Margin="0,3,0,0"
                                    FontFamily="{StaticResource FontUI}"
                                    FontSize="11"
                                    Foreground="{StaticResource BrushText2}"
                                    TextWrapping="Wrap"
                                    Text="• drag node header to move&#x0a;• right-click + drag empty canvas to pan&#x0a;• Ctrl + scroll to zoom&#x0a;• click a node to inspect" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
