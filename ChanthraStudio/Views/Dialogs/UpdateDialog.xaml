<Window
    x:Class="ChanthraStudio.Views.Dialogs.UpdateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Title="Update available"
    Width="620"
    Height="640"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="{StaticResource FontUI}"
    Foreground="{StaticResource BrushText1}"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="14" Background="Transparent">
        <Border CornerRadius="12" Effect="{StaticResource ShadowWindow}" />
        <Border
            Background="{StaticResource BrushBgMica}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="12">
            <Grid>
                <Border Background="{StaticResource BrushMicaCrimsonGlow}" />
                <Border Background="{StaticResource BrushMicaGoldGlow}" />
                <Border Background="{StaticResource BrushInnerTopHighlight}" Height="2" VerticalAlignment="Top" />

                <Grid Margin="22,16,22,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource TextPanelHeader}" FontSize="18">
                            <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                            <Run Text="Update available" />
                        </TextBlock>
                        <Button
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Click="Close_Click"
                            Style="{StaticResource ButtonIcon}">
                            <Path
                                Width="11"
                                Height="11"
                                Data="{StaticResource IcoClose}"
                                Stretch="Uniform"
                                Stroke="{StaticResource BrushText3}"
                                StrokeThickness="1.4" />
                        </Button>
                    </Grid>

                    <!--  Version row  -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Padding="14,10"
                            Background="{StaticResource BrushBgInset}"
                            BorderBrush="{StaticResource BrushLineHairline}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource FontMono}" FontSize="9" Foreground="{StaticResource BrushText4}" Text="CURRENT" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="{StaticResource FontDisplay}"
                                    FontSize="20"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource BrushText2}"
                                    Text="{Binding Info.CurrentVersion, FallbackValue=0.0.0}" />
                            </StackPanel>
                        </Border>

                        <TextBlock
                            Grid.Column="1"
                            Margin="14,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontDisplay}"
                            FontSize="22"
                            Foreground="{StaticResource BrushGold}"
                            Text="→" />

                        <Border
                            Grid.Column="2"
                            Padding="14,10"
                            Background="#1FD4A76A"
                            BorderBrush="{StaticResource BrushLineGold}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource FontMono}" FontSize="9" Foreground="{StaticResource BrushGold}" Text="LATEST" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="{StaticResource FontDisplay}"
                                    FontSize="20"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource BrushGoldHi}"
                                    Text="{Binding Info.LatestVersion, FallbackValue=-}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  Release name + size row  -->
                    <Grid Grid.Row="2" Margin="2,10,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontFamily="{StaticResource FontDisplay}"
                            FontSize="14"
                            FontStyle="Italic"
                            Foreground="{StaticResource BrushText1}"
                            Text="{Binding Info.ReleaseName}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="1"
                            FontFamily="{StaticResource FontMono}"
                            FontSize="10"
                            Foreground="{StaticResource BrushText3}"
                            Text="{Binding Info.AssetSizeFormatted}" />
                    </Grid>

                    <!--  Release notes — Markdown shown raw  -->
                    <Border
                        Grid.Row="3"
                        Padding="14,10"
                        Background="{StaticResource BrushBgInset}"
                        BorderBrush="{StaticResource BrushLineHairline}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Margin="0,0,0,6"
                                FontFamily="{StaticResource FontMono}"
                                FontSize="9"
                                Foreground="{StaticResource BrushText4}"
                                Text="WHAT'S NEW" />
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <TextBlock
                                    FontFamily="{StaticResource FontMono}"
                                    FontSize="11"
                                    Foreground="{StaticResource BrushText1}"
                                    Text="{Binding Info.Notes}"
                                    TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!--  Progress bar  -->
                    <Grid Grid.Row="4" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                FontFamily="{StaticResource FontMono}"
                                FontSize="10"
                                Foreground="{StaticResource BrushText2}"
                                Text="{Binding Status}" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource FontMono}"
                                FontSize="10"
                                Foreground="{StaticResource BrushGoldHi}"
                                Text="{Binding ProgressLabel}" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Height="6"
                            Margin="0,8,0,0"
                            Background="{StaticResource BrushBgInset}"
                            CornerRadius="3">
                            <Border
                                HorizontalAlignment="Left"
                                Background="{StaticResource BrushSliderFill}"
                                CornerRadius="3"
                                Width="{Binding Progress, Converter={StaticResource PercentToWidth}, ConverterParameter=560}" />
                        </Border>
                    </Grid>

                    <!--  License gate notice  -->
                    <Border
                        Grid.Row="5"
                        Margin="0,12,0,0"
                        Padding="12,8"
                        Background="#0FFFFFFF"
                        CornerRadius="6">
                        <TextBlock
                            FontFamily="{StaticResource FontThai}"
                            FontSize="11"
                            Foreground="{StaticResource BrushText2}"
                            TextWrapping="Wrap">
                            <Run Text="ระบบอัพเดทอัตโนมัติต้องมี License key ที่ถูกต้องจาก " />
                            <Run Foreground="{StaticResource BrushGoldHi}" Text="xman4289.com " />
                            <Run Text="หากยังไม่มี กดปุ่ม “เปิดหน้า GitHub Releases” เพื่อโหลดแบบ manual" />
                        </TextBlock>
                    </Border>

                    <!--  Buttons  -->
                    <Grid Grid.Row="6" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Padding="12,8"
                            Command="{Binding OpenReleasePageCommand}"
                            Content="เปิดหน้า GitHub Releases"
                            Style="{StaticResource ButtonPill}" />
                        <Button
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Click="Close_Click"
                            Content="ภายหลัง"
                            Style="{StaticResource ButtonPill}" />
                        <Button
                            Grid.Column="3"
                            MinWidth="160"
                            Command="{Binding DownloadAndApplyCommand}"
                            Content="✦ INSTALL UPDATE"
                            Style="{StaticResource ButtonPillGold}" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
