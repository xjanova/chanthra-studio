<UserControl
    x:Class="ChanthraStudio.Views.UsageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:m="clr-namespace:ChanthraStudio.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Background="{StaticResource BrushBgBase}"
    d:DataContext="{d:DesignInstance vm:UsageViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:UsageViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource ThinScrollBar}" TargetType="ScrollBar" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border Grid.Row="0" Padding="32,18" Background="{StaticResource BrushSurface02}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource TextPanelHeader}" FontSize="22">
                        <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                        <Run Text="Usage &amp; cost" />
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0" Style="{StaticResource TextSecondary}" FontSize="12"
                               Text="คำนวณจากราคาจริงของ provider · บันทึกทุก call ที่ผ่านแอป · แปลงเป็นบาทตามเรท FX ที่ตั้งไว้" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <Border Margin="0,0,8,0" Padding="12,6" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText3}" Text="1 USD =" />
                            <TextBox Grid.Column="1" Width="56" Margin="6,0,0,0" Background="Transparent" BorderThickness="0" CaretBrush="{StaticResource BrushGoldHi}" FontFamily="{StaticResource FontMono}" FontSize="11.5" Foreground="{StaticResource BrushGoldHi}" TextAlignment="Right" Text="{Binding FxRate, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}" />
                            <TextBlock Grid.Column="1" Margin="0,0,-22,0" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource TextMono}" Foreground="{StaticResource BrushText3}" Text="THB" />
                        </Grid>
                    </Border>
                    <Button Padding="14,6" Command="{Binding RefreshCommand}" Content="↻ Refresh" Style="{StaticResource ButtonPill}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="32,18,32,18" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  Top stat cards  -->
                <ItemsControl ItemsSource="{Binding Buckets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:UsageBucket}">
                            <Border Margin="0,0,12,0" Padding="20,16" Style="{StaticResource SurfaceCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="{Binding Label}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource FontDisplay}" FontStyle="Italic" FontSize="32" Foreground="{StaticResource BrushGoldHi}" Text="{Binding AmountLabel}" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource TextMono}" Foreground="{StaticResource BrushText3}" Text="{Binding Sub}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Two-column breakdown  -->
                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  By provider  -->
                    <Border Grid.Column="0" Margin="0,0,12,0" Padding="20,16" Style="{StaticResource SurfaceCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="BY PROVIDER · LAST 30 DAYS" />
                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ByProvider}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:UsageBreakdown}">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource BrushText1}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource BrushGoldHi}" Text="{Binding AmountLabel}" />
                                            </Grid>
                                            <Border Grid.Row="1" Margin="0,4,0,0" Height="4" Background="{StaticResource BrushBgInset}" CornerRadius="2">
                                                <Border HorizontalAlignment="Left" Background="{StaticResource BrushSliderFill}" CornerRadius="2"
                                                        Width="{Binding WidthFraction, Converter={StaticResource MultiplyConverter}, ConverterParameter=440}" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  By model  -->
                    <Border Grid.Column="1" Padding="20,16" Style="{StaticResource SurfaceCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="TOP MODELS · LAST 30 DAYS" />
                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ByModel}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:UsageBreakdown}">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="{StaticResource FontMono}" FontSize="10.5" Foreground="{StaticResource BrushText1}" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource BrushGoldHi}" Text="{Binding AmountLabel}" />
                                            </Grid>
                                            <Border Grid.Row="1" Margin="0,4,0,0" Height="4" Background="{StaticResource BrushBgInset}" CornerRadius="2">
                                                <Border HorizontalAlignment="Left" Background="{StaticResource BrushSliderFill}" CornerRadius="2"
                                                        Width="{Binding WidthFraction, Converter={StaticResource MultiplyConverter}, ConverterParameter=440}" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!--  Recent events table  -->
                <Border Margin="0,24,0,0" Padding="20,16" Style="{StaticResource SurfaceCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="RECENT CALLS" />
                        <Grid Margin="0,12,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="WHEN" />
                            <TextBlock Grid.Column="1" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="PROVIDER" />
                            <TextBlock Grid.Column="2" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="MODEL" />
                            <TextBlock Grid.Column="3" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="UNITS" />
                            <TextBlock Grid.Column="4" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="COST" TextAlignment="Right" />
                        </Grid>
                        <Border BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="0,1,0,0" />
                        <ItemsControl ItemsSource="{Binding RecentEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:UsageEvent}">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="{StaticResource FontMono}" FontSize="10.5" Foreground="{StaticResource BrushText3}" Text="{Binding OccurredAt, StringFormat={}{0:MM-dd HH:mm}}" />
                                        <TextBlock Grid.Column="1" FontFamily="{StaticResource FontMono}" FontSize="10.5" Foreground="{StaticResource BrushText2}" Text="{Binding ProviderId}" />
                                        <TextBlock Grid.Column="2" FontFamily="{StaticResource FontMono}" FontSize="10.5" Foreground="{StaticResource BrushText1}" Text="{Binding ModelSlug}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" FontFamily="{StaticResource FontMono}" FontSize="10.5" Foreground="{StaticResource BrushText3}" Text="{Binding UnitLabel}" />
                                        <TextBlock Grid.Column="4" FontFamily="{StaticResource FontMono}" FontSize="10.5" Foreground="{StaticResource BrushGoldHi}" TextAlignment="Right" Text="{Binding CostThbLabel}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
