<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ============================================================
          Type system
          Display:  Cormorant Garamond (brand, panel headers, italics)
          UI:       IBM Plex Sans (body / labels / buttons)
          Thai:     IBM Plex Sans Thai (mixed runs use UI as fallback)
          Mono:     IBM Plex Mono (timecodes, seeds, status)
          ============================================================  -->

    <FontFamily x:Key="FontDisplay">pack://application:,,,/Assets/Fonts/#Cormorant Garamond</FontFamily>
    <FontFamily x:Key="FontUI">pack://application:,,,/Assets/Fonts/#IBM Plex Sans</FontFamily>
    <FontFamily x:Key="FontThai">pack://application:,,,/Assets/Fonts/#IBM Plex Sans Thai, pack://application:,,,/Assets/Fonts/#IBM Plex Sans</FontFamily>
    <FontFamily x:Key="FontMono">pack://application:,,,/Assets/Fonts/#IBM Plex Mono</FontFamily>

    <!--  ============================================================
          Style presets
          ============================================================  -->

    <Style x:Key="TextDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize" Value="14.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource BrushText1}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style
        x:Key="TextDisplayItalic"
        BasedOn="{StaticResource TextDisplay}"
        TargetType="TextBlock">
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="Foreground" Value="{StaticResource BrushGoldHi}" />
    </Style>

    <Style x:Key="TextBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontThai}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="Foreground" Value="{StaticResource BrushText1}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style
        x:Key="TextLabel"
        BasedOn="{StaticResource TextBody}"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{StaticResource BrushText3}" />
    </Style>

    <Style x:Key="TextSecondary" BasedOn="{StaticResource TextBody}" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushText2}" />
    </Style>

    <Style x:Key="TextMono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource BrushText3}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style
        x:Key="TextMonoUpper"
        BasedOn="{StaticResource TextMono}"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{StaticResource BrushText3}" />
    </Style>

    <Style
        x:Key="TextMonoGold"
        BasedOn="{StaticResource TextMono}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushGold}" />
    </Style>

    <Style x:Key="TextSectionDivider" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
        <Setter Property="FontSize" Value="9.5" />
        <Setter Property="Foreground" Value="{StaticResource BrushText3}" />
    </Style>

    <Style x:Key="TextWordmarkBrand" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize" Value="14.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource BrushText1}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="TextSummonCta" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="#FF1A0D05" />
    </Style>

    <Style x:Key="TextPanelHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize" Value="14.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource BrushText1}" />
    </Style>

    <Style x:Key="TextWatermark" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#8CF0E7D4" />
    </Style>

</ResourceDictionary>
