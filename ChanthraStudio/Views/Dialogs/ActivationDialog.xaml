<Window
    x:Class="ChanthraStudio.Views.Dialogs.ActivationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Title="License activation"
    Width="540"
    Height="540"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="{StaticResource FontUI}"
    Foreground="{StaticResource BrushText1}"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.DataContext>
        <vm:ActivationViewModel />
    </Window.DataContext>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="14" Background="Transparent">
        <Border CornerRadius="12" Effect="{StaticResource ShadowWindow}" />
        <Border
            Background="{StaticResource BrushBgMica}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="12">
            <Grid>
                <Border Background="{StaticResource BrushMicaCrimsonGlow}" />
                <Border Background="{StaticResource BrushMicaGoldGlow}" />
                <Border Background="{StaticResource BrushInnerTopHighlight}" Height="2" VerticalAlignment="Top" />

                <Grid Margin="22,16,22,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource TextPanelHeader}" FontSize="18">
                            <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                            <Run Text="License activation" />
                        </TextBlock>
                        <Button
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Click="Close_Click"
                            Style="{StaticResource ButtonIcon}">
                            <Path
                                Width="11"
                                Height="11"
                                Data="{StaticResource IcoClose}"
                                Stretch="Uniform"
                                Stroke="{StaticResource BrushText3}"
                                StrokeThickness="1.4" />
                        </Button>
                    </Grid>

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,6,0,18"
                        FontFamily="{StaticResource FontThai}"
                        FontSize="12"
                        Foreground="{StaticResource BrushText2}"
                        TextWrapping="Wrap"
                        Text="ใส่ License key ที่ซื้อจาก xman4289.com เพื่อเปิดใช้งานระบบอัพเดทอัตโนมัติและฟีเจอร์เต็มของ Chanthra Studio" />

                    <!--  License key field  -->
                    <Border
                        Grid.Row="2"
                        Padding="0"
                        Background="{StaticResource BrushBgInset}"
                        BorderBrush="{StaticResource BrushLineHairline}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="KeyBox"
                                Grid.Column="0"
                                Padding="14,12"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="{StaticResource FontMono}"
                                FontSize="13"
                                Foreground="{StaticResource BrushText1}"
                                CaretBrush="{StaticResource BrushGoldHi}"
                                Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Column="0"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource FontMono}"
                                FontSize="13"
                                Foreground="{StaticResource BrushText4}"
                                IsHitTestVisible="False"
                                Text="CHS-XXXX-XXXX-XXXX">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LicenseKey}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button
                                Grid.Column="1"
                                Margin="0,0,8,0"
                                Padding="10,4"
                                Command="{Binding BuyCommand}"
                                Content="ซื้อ key"
                                Style="{StaticResource ButtonPill}" />
                        </Grid>
                    </Border>

                    <!--  Status panel — current license  -->
                    <Border
                        Grid.Row="3"
                        Margin="0,12,0,0"
                        Padding="14,12"
                        Background="{StaticResource BrushBgInset}"
                        BorderBrush="{StaticResource BrushLineHairline}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="{StaticResource FontMono}" FontSize="9" Foreground="{StaticResource BrushText4}" Text="STATUS" />
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    FontFamily="{StaticResource FontMono}"
                                    FontSize="11"
                                    Foreground="{StaticResource BrushText1}"
                                    Text="{Binding Current.DisplayLine}" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="{StaticResource FontMono}" FontSize="9" Foreground="{StaticResource BrushText4}" Text="MACHINE ID" />
                                <Grid Grid.Column="1" HorizontalAlignment="Right">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,8,0"
                                        FontFamily="{StaticResource FontMono}"
                                        FontSize="11"
                                        Foreground="{StaticResource BrushText2}"
                                        Text="{Binding MachineId}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Button
                                        Grid.Column="1"
                                        Padding="6,2"
                                        Command="{Binding CopyMachineIdCommand}"
                                        Content="copy"
                                        Style="{StaticResource ButtonPill}" />
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  Status message line  -->
                    <TextBlock
                        Grid.Row="4"
                        Margin="2,12,0,0"
                        FontFamily="{StaticResource FontMono}"
                        FontSize="10.5"
                        Foreground="{StaticResource BrushGoldHi}"
                        Text="{Binding StatusMessage}"
                        TextWrapping="Wrap" />

                    <!--  Help section  -->
                    <Border
                        Grid.Row="5"
                        Margin="0,16,0,0"
                        Padding="14,12"
                        Background="#0FFFFFFF"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock FontFamily="{StaticResource FontMono}" FontSize="9" Foreground="{StaticResource BrushText4}" Text="HOW IT WORKS" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontFamily="{StaticResource FontThai}"
                                FontSize="11"
                                Foreground="{StaticResource BrushText2}"
                                TextWrapping="Wrap">
                                <Run Text="• " /><Run Foreground="{StaticResource BrushGold}" Text="ซื้อ key " /><Run Text="ผ่านปุ่ม “ซื้อ key” → จะเปิดหน้าร้านที่ xman4289.com" /><LineBreak />
                                <Run Text="• " /><Run Foreground="{StaticResource BrushGold}" Text="วาง key " /><Run Text="ที่ส่งให้ทางอีเมล แล้วกด Activate" /><LineBreak />
                                <Run Text="• " /><Run Foreground="{StaticResource BrushGold}" Text="1 key = 1 เครื่อง " /><Run Text="ถ้าจะย้ายเครื่อง ให้กด Deactivate ก่อน" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!--  Buttons  -->
                    <Grid Grid.Row="7" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Padding="12,8"
                            Command="{Binding DeactivateCommand}"
                            Content="deactivate"
                            Style="{StaticResource ButtonPill}" />
                        <Button
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Click="Close_Click"
                            Content="close"
                            Style="{StaticResource ButtonPill}" />
                        <Button
                            Grid.Column="3"
                            Width="120"
                            Command="{Binding ActivateCommand}"
                            Content="✦ ACTIVATE"
                            Style="{StaticResource ButtonPillGold}" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
