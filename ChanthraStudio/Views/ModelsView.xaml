<UserControl
    x:Class="ChanthraStudio.Views.ModelsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:m="clr-namespace:ChanthraStudio.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource BrushBgBase}"
    d:DataContext="{d:DesignInstance m:ModelsViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <m:ModelsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style BasedOn="{StaticResource ThinScrollBar}" TargetType="ScrollBar" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Padding="32,18"
            Background="{StaticResource BrushSurface02}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource TextPanelHeader}">
                        <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                        <Run Text="Models" />
                    </TextBlock>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            Padding="8,3"
                            VerticalAlignment="Center"
                            CornerRadius="99">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1FE0B056" />
                                    <Setter Property="BorderBrush" Value="#66E0B056" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="ok">
                                            <Setter Property="Background" Value="#1F6DBF8C" />
                                            <Setter Property="BorderBrush" Value="#666DBF8C" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="err">
                                            <Setter Property="Background" Value="#1FD05A5A" />
                                            <Setter Property="BorderBrush" Value="#66D05A5A" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock
                                FontFamily="{StaticResource FontMono}"
                                FontSize="10"
                                Foreground="{StaticResource BrushText1}"
                                Text="{Binding ServerStatus}" />
                        </Border>
                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource TextMono}"
                            Foreground="{StaticResource BrushText3}"
                            Text="{Binding ServerUrl}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Style="{StaticResource TextMono}"
                            Foreground="{StaticResource BrushText2}"
                            Text="{Binding TotalLabel}" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <Border
                        Width="240"
                        Margin="0,0,8,0"
                        Padding="10,0"
                        Background="{StaticResource BrushBgInset}"
                        BorderBrush="{StaticResource BrushLineHairline}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBox
                            Height="32"
                            Style="{StaticResource SearchTextBox}"
                            Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                    <Button
                        Padding="14,6"
                        Command="{Binding RefreshCommand}"
                        Content="↻ Refresh"
                        Style="{StaticResource ButtonPill}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Groups  -->
        <ScrollViewer Grid.Row="1" Padding="32,18,32,18" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:ModelGroup}">
                        <Border
                            Margin="0,0,0,18"
                            Padding="16,14"
                            Style="{StaticResource SurfaceCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontFamily="{StaticResource FontDisplay}"
                                        FontSize="15"
                                        FontStyle="Italic"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource BrushText1}"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource TextMonoUpper}">
                                        <Run Foreground="{StaticResource BrushGoldHi}" Text="{Binding Count, Mode=OneWay}" />
                                        <Run Foreground="{StaticResource BrushText3}" Text="/" />
                                        <Run Foreground="{StaticResource BrushText3}" Text="{Binding TotalCount, Mode=OneWay}" />
                                        <Run Foreground="{StaticResource BrushText3}" Text=" available" />
                                    </TextBlock>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="10,6"
                                                Background="{StaticResource BrushBgInset}"
                                                BorderBrush="{StaticResource BrushLineHairline}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <TextBlock
                                                    FontFamily="{StaticResource FontMono}"
                                                    FontSize="10.5"
                                                    Foreground="{StaticResource BrushText1}"
                                                    Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
