<UserControl
    x:Class="ChanthraStudio.Controls.Sidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Width="64"
    d:DataContext="{d:DesignInstance vm:MainViewModel}"
    d:DesignHeight="934"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,12,0,0">
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Generate"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Generate, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Generate">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoSparkle}"
                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    Stretch="Uniform" />
            </ToggleButton>
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Edit"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Edit, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Edit · NLE">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoScissors}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Voice"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Voice, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Sound atelier">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoMic}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Flow"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Flow, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Node flow">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoNode}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Library"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Library, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Library">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoLibrary}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Models"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Models, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Models">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoBrain}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Queue"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Queue, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Queue">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoQueue}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Schedule"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Schedule, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Auto-schedule">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoClock}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,16"
            HorizontalAlignment="Center">
            <ToggleButton
                Command="{Binding SwitchViewCommand}"
                CommandParameter="Settings"
                IsChecked="{Binding ActiveView, Converter={StaticResource EnumEquals}, ConverterParameter=Settings, Mode=OneWay}"
                Style="{StaticResource SidebarItem}"
                ToolTip="Settings">
                <Path
                    Width="19"
                    Height="19"
                    Data="{StaticResource IcoSettings}"
                    Stretch="Uniform"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.4" />
            </ToggleButton>

            <Border
                Width="32"
                Height="32"
                Margin="0,8,0,0"
                Background="{StaticResource BrushAvatar}"
                BorderBrush="{StaticResource BrushGold}"
                BorderThickness="1"
                CornerRadius="16">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource FontDisplay}"
                    FontSize="14"
                    FontStyle="Italic"
                    FontWeight="Medium"
                    Foreground="#FF1A0D05"
                    Text="J" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
