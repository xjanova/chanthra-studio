<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ============================================================
          Drop shadows / glows — millennium dimensional set
          WPF DropShadowEffect is single-layer per effect, so multi-
          layer glows are stacked Borders (see Window in MainWindow).
          ============================================================  -->

    <!--  Window outer cast — deep, soft, far  -->
    <DropShadowEffect
        x:Key="ShadowWindow"
        BlurRadius="120"
        Direction="270"
        Opacity="0.85"
        ShadowDepth="50"
        Color="#FF000000" />

    <!--  Window outer warm tint — sits underneath ShadowWindow  -->
    <DropShadowEffect
        x:Key="ShadowWindowWarm"
        BlurRadius="80"
        Direction="270"
        Opacity="0.35"
        ShadowDepth="30"
        Color="#FF785028" />

    <!--  Canvas frame: gold tint  -->
    <DropShadowEffect
        x:Key="ShadowCanvas"
        BlurRadius="80"
        Direction="270"
        Opacity="0.32"
        ShadowDepth="22"
        Color="{StaticResource ColorGold}" />

    <DropShadowEffect
        x:Key="ShadowCanvasCrimson"
        BlurRadius="60"
        Direction="270"
        Opacity="0.18"
        ShadowDepth="22"
        Color="{StaticResource ColorCrimson}" />

    <!--  Gold glows  -->
    <DropShadowEffect
        x:Key="ShadowGoldGlow"
        BlurRadius="24"
        Opacity="0.55"
        ShadowDepth="0"
        Color="{StaticResource ColorGold}" />

    <DropShadowEffect
        x:Key="ShadowGoldGlowSoft"
        BlurRadius="10"
        Opacity="0.8"
        ShadowDepth="0"
        Color="{StaticResource ColorGoldHi}" />

    <DropShadowEffect
        x:Key="ShadowGoldGlowStrong"
        BlurRadius="32"
        Opacity="0.7"
        ShadowDepth="0"
        Color="{StaticResource ColorGoldHi}" />

    <!--  Summon CTA: deeper, warmer  -->
    <DropShadowEffect
        x:Key="ShadowSummonCta"
        BlurRadius="28"
        Opacity="0.45"
        ShadowDepth="6"
        Color="{StaticResource ColorGold}" />

    <!--  Card base shadow (always-on subtle lift)  -->
    <DropShadowEffect
        x:Key="ShadowCardRest"
        BlurRadius="14"
        Direction="270"
        Opacity="0.5"
        ShadowDepth="6"
        Color="#FF000000" />

    <!--  Card hover lift  -->
    <DropShadowEffect
        x:Key="ShadowCardLift"
        BlurRadius="22"
        Direction="270"
        Opacity="0.32"
        ShadowDepth="10"
        Color="{StaticResource ColorGold}" />

    <!--  Crimson silk shadow  -->
    <DropShadowEffect
        x:Key="ShadowCrimsonGlow"
        BlurRadius="22"
        Opacity="0.6"
        ShadowDepth="0"
        Color="{StaticResource ColorCrimson}" />

    <!--  Mauve glow  -->
    <DropShadowEffect
        x:Key="ShadowMoonGlow"
        BlurRadius="16"
        Opacity="0.55"
        ShadowDepth="0"
        Color="{StaticResource ColorMoon}" />

    <!--  Glassmorphic blur  -->
    <BlurEffect x:Key="EffectGlassBlur" KernelType="Gaussian" Radius="14" />
    <BlurEffect x:Key="EffectGlassBlurLight" KernelType="Gaussian" Radius="6" />

</ResourceDictionary>
