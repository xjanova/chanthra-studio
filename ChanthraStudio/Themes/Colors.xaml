<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ============================================================
          Chanthra Studio · Lunar Atelier Color System
          Tokens mirror styles.css from design handoff.
          Use {DynamicResource ColorXxx} for re-themable consumers,
          {StaticResource BrushXxx} for the materialized brushes.
          ============================================================  -->

    <!--  Backdrops & surfaces  -->
    <Color x:Key="ColorVoid">#FF060409</Color>
    <Color x:Key="ColorBgBase">#FF0C0814</Color>
    <Color x:Key="ColorBgMica">#FF120C1C</Color>
    <Color x:Key="ColorBgSurface">#FF160F22</Color>
    <Color x:Key="ColorBgElevated">#FF1D1530</Color>
    <Color x:Key="ColorBgInset">#FF0A0612</Color>

    <!--  Gold (primary accent)  -->
    <Color x:Key="ColorGold">#FFD4A76A</Color>
    <Color x:Key="ColorGoldHi">#FFF0CB88</Color>
    <Color x:Key="ColorGoldLo">#FF8B6938</Color>
    <Color x:Key="ColorGoldSoft">#FFB5915C</Color>

    <!--  Crimson silk  -->
    <Color x:Key="ColorCrimson">#FFB03346</Color>
    <Color x:Key="ColorCrimsonDeep">#FF6E1F2C</Color>

    <!--  Moon mauve  -->
    <Color x:Key="ColorMoon">#FFD8D0E6</Color>
    <Color x:Key="ColorMoonDeep">#FF6C5E85</Color>
    <Color x:Key="ColorPlum">#FF2A1B3D</Color>
    <Color x:Key="ColorPlumLight">#FF4A2E6A</Color>

    <!--  Text  -->
    <Color x:Key="ColorText1">#FFF0E7D4</Color>
    <Color x:Key="ColorText2">#FFB8AEC0</Color>
    <Color x:Key="ColorText3">#FF7D7388</Color>
    <Color x:Key="ColorText4">#FF514A5D</Color>

    <!--  Status  -->
    <Color x:Key="ColorOk">#FF6DBF8C</Color>
    <Color x:Key="ColorWarn">#FFE0B056</Color>
    <Color x:Key="ColorErr">#FFD05A5A</Color>

    <!--  Lines  -->
    <Color x:Key="ColorLineHairline">#0FE8D5B3</Color>
    <Color x:Key="ColorLineGold">#38D4A76A</Color>
    <Color x:Key="ColorLineCrimson">#52B03346</Color>

    <!--  ============================================================
          Materialised brushes — bind via {StaticResource BrushXxx}
          ============================================================  -->
    <SolidColorBrush x:Key="BrushVoid" Color="{StaticResource ColorVoid}" />
    <SolidColorBrush x:Key="BrushBgBase" Color="{StaticResource ColorBgBase}" />
    <SolidColorBrush x:Key="BrushBgMica" Color="{StaticResource ColorBgMica}" />
    <SolidColorBrush x:Key="BrushBgSurface" Color="{StaticResource ColorBgSurface}" />
    <SolidColorBrush x:Key="BrushBgElevated" Color="{StaticResource ColorBgElevated}" />
    <SolidColorBrush x:Key="BrushBgInset" Color="{StaticResource ColorBgInset}" />

    <SolidColorBrush x:Key="BrushGold" Color="{StaticResource ColorGold}" />
    <SolidColorBrush x:Key="BrushGoldHi" Color="{StaticResource ColorGoldHi}" />
    <SolidColorBrush x:Key="BrushGoldLo" Color="{StaticResource ColorGoldLo}" />
    <SolidColorBrush x:Key="BrushGoldSoft" Color="{StaticResource ColorGoldSoft}" />

    <SolidColorBrush x:Key="BrushCrimson" Color="{StaticResource ColorCrimson}" />
    <SolidColorBrush x:Key="BrushCrimsonDeep" Color="{StaticResource ColorCrimsonDeep}" />

    <SolidColorBrush x:Key="BrushMoon" Color="{StaticResource ColorMoon}" />
    <SolidColorBrush x:Key="BrushMoonDeep" Color="{StaticResource ColorMoonDeep}" />
    <SolidColorBrush x:Key="BrushPlum" Color="{StaticResource ColorPlum}" />
    <SolidColorBrush x:Key="BrushPlumLight" Color="{StaticResource ColorPlumLight}" />

    <SolidColorBrush x:Key="BrushText1" Color="{StaticResource ColorText1}" />
    <SolidColorBrush x:Key="BrushText2" Color="{StaticResource ColorText2}" />
    <SolidColorBrush x:Key="BrushText3" Color="{StaticResource ColorText3}" />
    <SolidColorBrush x:Key="BrushText4" Color="{StaticResource ColorText4}" />

    <SolidColorBrush x:Key="BrushOk" Color="{StaticResource ColorOk}" />
    <SolidColorBrush x:Key="BrushWarn" Color="{StaticResource ColorWarn}" />
    <SolidColorBrush x:Key="BrushErr" Color="{StaticResource ColorErr}" />

    <SolidColorBrush x:Key="BrushLineHairline" Color="{StaticResource ColorLineHairline}" />
    <SolidColorBrush x:Key="BrushLineGold" Color="{StaticResource ColorLineGold}" />
    <SolidColorBrush x:Key="BrushLineCrimson" Color="{StaticResource ColorLineCrimson}" />

    <!--  Translucent overlays  -->
    <SolidColorBrush x:Key="BrushHover03" Color="#08FFFFFF" />
    <SolidColorBrush x:Key="BrushHover06" Color="#0FFFFFFF" />
    <SolidColorBrush x:Key="BrushSurface02" Color="#05FFFFFF" />
    <SolidColorBrush x:Key="BrushSurface03" Color="#08FFFFFF" />
    <SolidColorBrush x:Key="BrushBlackOverlay35" Color="#59000000" />
    <SolidColorBrush x:Key="BrushBlackOverlay55" Color="#8C000000" />
    <SolidColorBrush x:Key="BrushBlackOverlay65" Color="#A6000000" />

    <!--  ============================================================
          Gold / crimson gradients (CTAs, clip strips, sliders)
          ============================================================  -->

    <!--  Generate "Summon Scene" button — tri-stop gold  -->
    <LinearGradientBrush x:Key="BrushSummonCta" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource ColorGoldLo}" />
        <GradientStop Offset="0.5" Color="{StaticResource ColorGold}" />
        <GradientStop Offset="1" Color="{StaticResource ColorGoldHi}" />
    </LinearGradientBrush>

    <!--  Slider fill (horizontal)  -->
    <LinearGradientBrush x:Key="BrushSliderFill" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Offset="0" Color="{StaticResource ColorGoldLo}" />
        <GradientStop Offset="1" Color="{StaticResource ColorGoldHi}" />
    </LinearGradientBrush>

    <!--  Brand mark moon — radial gold  -->
    <RadialGradientBrush x:Key="BrushBrandMoon" Center="0.45,0.4" GradientOrigin="0.45,0.4" RadiusX="0.7" RadiusY="0.7">
        <GradientStop Offset="0" Color="{StaticResource ColorGoldHi}" />
        <GradientStop Offset="1" Color="{StaticResource ColorGoldLo}" />
    </RadialGradientBrush>

    <!--  Avatar — diagonal gold→crimson  -->
    <LinearGradientBrush x:Key="BrushAvatar" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource ColorGoldSoft}" />
        <GradientStop Offset="1" Color="{StaticResource ColorCrimson}" />
    </LinearGradientBrush>

    <!--  Engine badge — diagonal plum  -->
    <LinearGradientBrush x:Key="BrushEngineBadge" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource ColorPlum}" />
        <GradientStop Offset="1" Color="#FF1A1124" />
    </LinearGradientBrush>

    <!--  Active tab underline  -->
    <LinearGradientBrush x:Key="BrushActiveTabUnderline" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Offset="0" Color="#00D4A76A" />
        <GradientStop Offset="0.5" Color="{StaticResource ColorGold}" />
        <GradientStop Offset="1" Color="#00D4A76A" />
    </LinearGradientBrush>

    <!--  Clip variant gradients (timeline / NLE)  -->
    <LinearGradientBrush x:Key="BrushClipCrimson" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="{StaticResource ColorCrimson}" />
        <GradientStop Offset="1" Color="{StaticResource ColorCrimsonDeep}" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrushClipAmber" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="{StaticResource ColorGold}" />
        <GradientStop Offset="1" Color="{StaticResource ColorGoldLo}" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrushClipGold" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="{StaticResource ColorGoldHi}" />
        <GradientStop Offset="1" Color="{StaticResource ColorGoldSoft}" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrushClipPlum" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="{StaticResource ColorPlumLight}" />
        <GradientStop Offset="1" Color="{StaticResource ColorPlum}" />
    </LinearGradientBrush>

    <!--  Master mica multi-layer (window background) — beefed with deeper falloffs  -->
    <RadialGradientBrush x:Key="BrushMicaCrimsonGlow" Center="0.85,-0.05" GradientOrigin="0.85,-0.05" RadiusX="0.7" RadiusY="0.6">
        <GradientStop Offset="0" Color="#26B03346" />
        <GradientStop Offset="0.55" Color="#0CB03346" />
        <GradientStop Offset="0.85" Color="#00B03346" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="BrushMicaGoldGlow" Center="-0.05,1.05" GradientOrigin="-0.05,1.05" RadiusX="0.65" RadiusY="0.55">
        <GradientStop Offset="0" Color="#1ED4A76A" />
        <GradientStop Offset="0.55" Color="#0AD4A76A" />
        <GradientStop Offset="0.85" Color="#00D4A76A" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="BrushMicaMauveMid" Center="0.5,0.3" GradientOrigin="0.5,0.3" RadiusX="0.5" RadiusY="0.7">
        <GradientStop Offset="0" Color="#186C5E85" />
        <GradientStop Offset="0.7" Color="#006C5E85" />
    </RadialGradientBrush>

    <!--  Millennium iridescent shimmer — diagonal sheen across whole window  -->
    <LinearGradientBrush x:Key="BrushIridescentSheen" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#00FFFFFF" />
        <GradientStop Offset="0.35" Color="#00FFFFFF" />
        <GradientStop Offset="0.5" Color="#0AF0CB88" />
        <GradientStop Offset="0.6" Color="#0BB8A5D0" />
        <GradientStop Offset="0.7" Color="#08D8A0A8" />
        <GradientStop Offset="0.85" Color="#00FFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </LinearGradientBrush>

    <!--  Inner top highlight — used as 1px gradient inset to fake bevel  -->
    <LinearGradientBrush x:Key="BrushInnerTopHighlight" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#1FFFFFFF" />
        <GradientStop Offset="0.04" Color="#08FFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </LinearGradientBrush>

    <!--  Inner bottom shadow — pairs with InnerTopHighlight for chiseled feel  -->
    <LinearGradientBrush x:Key="BrushInnerBottomShadow" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#00000000" />
        <GradientStop Offset="0.94" Color="#10000000" />
        <GradientStop Offset="1" Color="#28000000" />
    </LinearGradientBrush>

    <!--  Frosted glass surface (used on canvas playback bar)  -->
    <LinearGradientBrush x:Key="BrushGlassSurface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#A6160F22" />
        <GradientStop Offset="1" Color="#BF06040D" />
    </LinearGradientBrush>

    <!--  Card surface gradient (subtle top-light, bottom-dark)  -->
    <LinearGradientBrush x:Key="BrushCardElevation" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#FF1A1230" />
        <GradientStop Offset="1" Color="#FF12091E" />
    </LinearGradientBrush>

    <!--  Crimson→gold→mauve micro-gradient for active accents  -->
    <LinearGradientBrush x:Key="BrushMillenniumAccent" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource ColorCrimson}" />
        <GradientStop Offset="0.5" Color="{StaticResource ColorGoldHi}" />
        <GradientStop Offset="1" Color="{StaticResource ColorMoonDeep}" />
    </LinearGradientBrush>

</ResourceDictionary>
