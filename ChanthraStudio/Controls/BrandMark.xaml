<UserControl
    x:Class="ChanthraStudio.Controls.BrandMark"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="22"
    Height="22"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">
    <Grid>
        <!--  thin gold outer ring  -->
        <Ellipse
            Stroke="{StaticResource BrushGold}"
            StrokeThickness="0.8"
            Opacity="0.85" />

        <!--  Crescent moon: outer disc minus offset disc  -->
        <Path Effect="{StaticResource ShadowGoldGlowSoft}" Fill="{StaticResource BrushBrandMoon}">
            <Path.Data>
                <CombinedGeometry GeometryCombineMode="Exclude">
                    <CombinedGeometry.Geometry1>
                        <EllipseGeometry
                            Center="11,11"
                            RadiusX="7.5"
                            RadiusY="7.5" />
                    </CombinedGeometry.Geometry1>
                    <CombinedGeometry.Geometry2>
                        <EllipseGeometry
                            Center="14.5,8.5"
                            RadiusX="6.5"
                            RadiusY="6.5" />
                    </CombinedGeometry.Geometry2>
                </CombinedGeometry>
            </Path.Data>
        </Path>
    </Grid>
</UserControl>
