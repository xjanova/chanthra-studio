<UserControl
    x:Class="ChanthraStudio.Views.VoiceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Background="{StaticResource BrushBgBase}"
    d:DataContext="{d:DesignInstance vm:VoiceViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toast  -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="0,18,0,0"
            Padding="14,8"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Panel.ZIndex="50"
            CornerRadius="99"
            Effect="{StaticResource ShadowGoldGlowSoft}"
            Visibility="{Binding ToastMessage, Converter={StaticResource NotNullOrEmpty}, FallbackValue=Collapsed}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource BrushSurface03}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushLineHairline}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ToastKind}" Value="ok">
                            <Setter Property="Background" Value="#1F6DBF8C" />
                            <Setter Property="BorderBrush" Value="#666DBF8C" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastKind}" Value="warn">
                            <Setter Property="Background" Value="#1FE0B056" />
                            <Setter Property="BorderBrush" Value="#66E0B056" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastKind}" Value="err">
                            <Setter Property="Background" Value="#1FD05A5A" />
                            <Setter Property="BorderBrush" Value="#66D05A5A" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastKind}" Value="info">
                            <Setter Property="Background" Value="#1FD4A76A" />
                            <Setter Property="BorderBrush" Value="#66D4A76A" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock FontFamily="{StaticResource FontUI}" FontSize="11.5" Foreground="{StaticResource BrushText1}" Text="{Binding ToastMessage}" />
        </Border>

        <!--  Header  -->
        <Grid Grid.Row="0" Margin="32,22,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource TextPanelHeader}" FontSize="22">
                    <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                    <Run Text="Sound atelier" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0" Style="{StaticResource TextSecondary}" FontSize="12">
                    <Run Text="TTS voices via OpenAI / ElevenLabs · music gen via Replicate (musicgen / ace-step / riffusion). Output drops into media/voice/ or media/music/." />
                </TextBlock>
            </StackPanel>
            <!--  Mode toggle: TTS · Music  -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                <Border
                    Padding="3"
                    Background="{StaticResource BrushBgInset}"
                    BorderBrush="{StaticResource BrushLineHairline}"
                    BorderThickness="1"
                    CornerRadius="99">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton
                            Margin="0,0,2,0"
                            Padding="14,4"
                            Command="{Binding SwitchToTtsCommand}"
                            Content="◔ TTS"
                            GroupName="voiceMode"
                            IsChecked="{Binding IsTtsMode, Mode=OneWay}"
                            Style="{StaticResource ChipRadio}" />
                        <RadioButton
                            Padding="14,4"
                            Command="{Binding SwitchToMusicCommand}"
                            Content="♪ Music"
                            GroupName="voiceMode"
                            IsChecked="{Binding IsMusicMode, Mode=OneWay}"
                            Style="{StaticResource ChipRadio}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!--  Body  -->
        <Grid Grid.Row="1" Margin="32,8,32,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!--  Left: TTS composer (visible in Tts mode)  -->
            <Border Grid.Column="0" Padding="20,18" Style="{StaticResource SurfaceCard}"
                    Visibility="{Binding IsTtsMode, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Provider + voice pickers  -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource TextMonoUpper}" Text="PROVIDER" />
                            <Border Margin="0,6,0,0" Padding="12,8" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="6">
                                <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider, Mode=TwoWay}" DisplayMemberPath="DisplayName" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Style="{StaticResource TextMonoUpper}" Text="VOICE" />
                            <Border Margin="0,6,0,0" Padding="12,8" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="6">
                                <ComboBox ItemsSource="{Binding Voices}" SelectedItem="{Binding SelectedVoice, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock FontFamily="{StaticResource FontUI}" FontSize="12.5" Foreground="{StaticResource BrushText1}" Text="{Binding DisplayName}" />
                                                <TextBlock Margin="0,2,0,0" Style="{StaticResource TextMonoUpper}" Text="{Binding Description}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!--  Brief + Write button  -->
                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TextMonoUpper}" Text="BRIEF · ONE LINE THE LLM EXPANDS" />
                            <TextBlock Grid.Column="1" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="{Binding ActiveLlmLabel, StringFormat=VIA {0}}" />
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Padding="12,8" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" CaretBrush="{StaticResource BrushGoldHi}" FontFamily="{StaticResource FontThai}" FontSize="12" Foreground="{StaticResource BrushText1}" Text="{Binding ScriptBrief, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                            <Button Grid.Column="1" Margin="8,0,0,0" Padding="14,8" Command="{Binding WriteScriptCommand}" Content="✦  Write"
                                    IsEnabled="{Binding IsWriting, Converter={StaticResource InvBoolToVis}, FallbackValue=True}"
                                    Style="{StaticResource ButtonPillGold}" />
                        </Grid>
                    </Grid>

                    <!--  Script  -->
                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Margin="0,0,0,6" Style="{StaticResource TextMonoUpper}" Text="SCRIPT" />
                        <Border Grid.Row="1" MinHeight="200" Padding="14,12" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="8">
                            <TextBox Background="Transparent" BorderThickness="0" CaretBrush="{StaticResource BrushGoldHi}" FontFamily="{StaticResource FontThai}" FontSize="14" Foreground="{StaticResource BrushText1}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding ScriptText, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </Grid>

                    <!--  Speed slider  -->
                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Speed" />
                        <Slider Grid.Column="1" Margin="6,0" Minimum="0.5" Maximum="2.0" SmallChange="0.05" LargeChange="0.25" Style="{StaticResource GoldSlider}" Value="{Binding Speed, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" Text="{Binding Speed, StringFormat={}{0:F2}×}" />
                    </Grid>

                    <!--  Stability slider (ElevenLabs only)  -->
                    <Grid Grid.Row="4" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Stability" />
                        <Slider Grid.Column="1" Margin="6,0" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.25" Style="{StaticResource GoldSlider}" Value="{Binding Stability, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" Text="{Binding Stability, StringFormat={}{0:F2}}" />
                    </Grid>

                    <!--  Generate CTA  -->
                    <Button Grid.Row="5" Margin="0,18,0,0" HorizontalAlignment="Right" Padding="22,8" Command="{Binding GenerateCommand}" Content="✦  Generate voice" Style="{StaticResource ButtonPillGold}"
                            IsEnabled="{Binding IsGenerating, Converter={StaticResource InvBoolToVis}, FallbackValue=True}" />
                </Grid>
            </Border>

            <!--  Left: Music composer (visible in Music mode)  -->
            <Border Grid.Column="0" Padding="20,18" Style="{StaticResource SurfaceCard}"
                    Visibility="{Binding IsMusicMode, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Music provider picker  -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource TextMonoUpper}" Text="MUSIC PROVIDER" />
                            <Border Margin="0,6,0,0" Padding="12,8" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="6">
                                <ComboBox ItemsSource="{Binding MusicProviders}" SelectedItem="{Binding SelectedMusicProvider, Mode=TwoWay}" DisplayMemberPath="DisplayName" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Style="{StaticResource TextMonoUpper}" Text="MODEL · OWNER/NAME" />
                            <Border Margin="0,6,0,0" Padding="12,8" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="6">
                                <TextBox Background="Transparent" BorderThickness="0" CaretBrush="{StaticResource BrushGoldHi}" FontFamily="{StaticResource FontMono}" FontSize="12" Foreground="{StaticResource BrushText1}" Text="{Binding MusicModel, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!--  Quick-pick model chips  -->
                    <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="QUICK PICK" />
                        <RadioButton Margin="10,0,4,0" Content="meta/musicgen" GroupName="musicQuick"
                                     Click="MusicQuickPick_Click" Tag="meta/musicgen" Style="{StaticResource ChipRadio}" />
                        <RadioButton Margin="0,0,4,0" Content="lucataco/ace-step" GroupName="musicQuick"
                                     Click="MusicQuickPick_Click" Tag="lucataco/ace-step" Style="{StaticResource ChipRadio}" />
                        <RadioButton Margin="0,0,4,0" Content="riffusion/riffusion" GroupName="musicQuick"
                                     Click="MusicQuickPick_Click" Tag="riffusion/riffusion" Style="{StaticResource ChipRadio}" />
                    </StackPanel>

                    <!--  Music prompt  -->
                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Margin="0,0,0,6" Style="{StaticResource TextMonoUpper}" Text="MUSIC PROMPT · STYLE / TEMPO / INSTRUMENTS" />
                        <Border Grid.Row="1" MinHeight="200" Padding="14,12" Background="{StaticResource BrushBgInset}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="8">
                            <TextBox Background="Transparent" BorderThickness="0" CaretBrush="{StaticResource BrushGoldHi}" FontFamily="{StaticResource FontThai}" FontSize="13" Foreground="{StaticResource BrushText1}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding MusicPrompt, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </Grid>

                    <!--  Duration slider  -->
                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Duration" />
                        <Slider Grid.Column="1" Margin="6,0" Minimum="4" Maximum="120" SmallChange="1" LargeChange="10" Style="{StaticResource GoldSlider}" Value="{Binding MusicDuration, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" Text="{Binding MusicDuration, StringFormat={}{0:F0}s}" />
                    </Grid>

                    <!--  Generate music CTA  -->
                    <Button Grid.Row="4" Margin="0,18,0,0" HorizontalAlignment="Right" Padding="22,8" Command="{Binding GenerateMusicCommand}" Content="♪  Generate music" Style="{StaticResource ButtonPillGold}"
                            IsEnabled="{Binding IsGenerating, Converter={StaticResource InvBoolToVis}, FallbackValue=True}" />
                </Grid>
            </Border>

            <!--  Right: takes (TTS or Music depending on mode)  -->
            <Border Grid.Column="1" Margin="14,0,0,0" Padding="16,14" Style="{StaticResource SurfaceCard}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource TextPanelHeader}">
                            <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                            <Run Text="{Binding IsTtsMode, Converter={StaticResource BoolToVis}, FallbackValue=Takes}" />
                            <Run Text="Takes" />
                        </TextBlock>
                        <Button Grid.Column="1" Padding="10,4" Command="{Binding RefreshTakesCommand}" Content="Refresh" Style="{StaticResource ButtonPill}" />
                    </Grid>

                    <TextBlock DockPanel.Dock="Top"
                               Style="{StaticResource TextSecondary}" FontSize="11"
                               Margin="0,0,0,12"
                               Visibility="{Binding HasTakes, Converter={StaticResource InvBoolToVis}}"
                               TextWrapping="Wrap"
                               Text="No takes yet. Generated audio appears here, sorted newest first." />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding Takes}"
                                          Visibility="{Binding IsTtsMode, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BrushBgInset}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Command="{Binding DataContext.PlayTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Play" />
                                                <MenuItem Command="{Binding DataContext.RevealTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Reveal in Explorer" />
                                                <MenuItem Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Copy path" />
                                                <Separator />
                                                <MenuItem Command="{Binding DataContext.DeleteTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Delete take" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Width="32" Height="32" Margin="0,0,10,0" Command="{Binding DataContext.PlayTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource ButtonSummonCta}" Padding="0">
                                                <Path Width="11" Height="11" Data="{StaticResource IcoPlay}" Fill="#FF1A0D05" Stretch="Uniform" />
                                            </Button>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontFamily="{StaticResource FontUI}" FontSize="11.5" Foreground="{StaticResource BrushText1}" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource TextMonoUpper}" Text="{Binding ProviderDisplayName}" />
                                                    <TextBlock Margin="6,0,0,0" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushText4}" Text="·" />
                                                    <TextBlock Margin="6,0,0,0" Style="{StaticResource TextMonoUpper}" Text="{Binding VoiceDisplayName}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" FontSize="10.5" Text="{Binding DurationLabel}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                            <ItemsControl ItemsSource="{Binding MusicTakes}"
                                          Visibility="{Binding IsMusicMode, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="12,10" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BrushBgInset}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Command="{Binding DataContext.PlayTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Play" />
                                                    <MenuItem Command="{Binding DataContext.RevealTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Reveal in Explorer" />
                                                    <MenuItem Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Copy path" />
                                                    <Separator />
                                                    <MenuItem Command="{Binding DataContext.DeleteTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Header="Delete take" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Width="32" Height="32" Margin="0,0,10,0" Command="{Binding DataContext.PlayTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource ButtonSummonCta}" Padding="0">
                                                    <Path Width="11" Height="11" Data="{StaticResource IcoPlay}" Fill="#FF1A0D05" Stretch="Uniform" />
                                                </Button>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock FontFamily="{StaticResource FontUI}" FontSize="11.5" Foreground="{StaticResource BrushText1}" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                                        <TextBlock Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushGoldHi}" Text="♪" />
                                                        <TextBlock Margin="6,0,0,0" Style="{StaticResource TextMonoUpper}" Text="{Binding VoiceDisplayName}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" FontSize="10.5" Text="{Binding DurationLabel}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
