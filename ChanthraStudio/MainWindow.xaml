<Window
    x:Class="ChanthraStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:ChanthraStudio.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:views="clr-namespace:ChanthraStudio.Views"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Title="Chanthra Studio"
    Width="1640"
    Height="1000"
    MinWidth="1320"
    MinHeight="880"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="{StaticResource FontUI}"
    Foreground="{StaticResource BrushText1}"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="ViewSwitcher" TargetType="ContentControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ActiveView}" Value="Generate">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:GenerateView DataContext="{Binding Generate}" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActiveView}" Value="Edit">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:StubView Tag="Editor · NLE" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActiveView}" Value="Voice">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:StubView Tag="Sound atelier" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActiveView}" Value="Flow">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:StubView Tag="Node flow" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActiveView}" Value="Library">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:StubView Tag="Library" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActiveView}" Value="Models">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:StubView Tag="Models" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActiveView}" Value="Queue">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:StubView Tag="Queue" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ActiveView}" Value="Settings">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:StubView Tag="Settings" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="38"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Border
            x:Name="MainBorder"
            Background="{StaticResource BrushBgMica}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="12"
            Effect="{StaticResource ShadowWindow}">
            <Grid>
                <Border Background="{StaticResource BrushMicaCrimsonGlow}" />
                <Border Background="{StaticResource BrushMicaGoldGlow}" />
                <Border Background="{StaticResource BrushMicaMauveMid}" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Background="Transparent"
                        BorderBrush="{StaticResource BrushLineHairline}"
                        BorderThickness="0,0,0,1">
                        <c:TitleBar />
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Background="Transparent"
                            BorderBrush="{StaticResource BrushLineHairline}"
                            BorderThickness="0,0,1,0">
                            <c:Sidebar />
                        </Border>
                        <ContentControl Grid.Column="1" Style="{StaticResource ViewSwitcher}" />
                    </Grid>

                    <c:StatusBar Grid.Row="2" DataContext="{Binding Status}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
