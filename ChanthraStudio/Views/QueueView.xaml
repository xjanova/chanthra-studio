<UserControl
    x:Class="ChanthraStudio.Views.QueueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Background="{StaticResource BrushBgBase}"
    d:DataContext="{d:DesignInstance vm:QueueViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="32,22,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource TextPanelHeader}" FontSize="22">
                    <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                    <Run Text="Queue" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0" Style="{StaticResource TextSecondary}" FontSize="12" Text="{Binding Summary}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Command="{Binding RefreshCommand}"
                Content="Refresh"
                Style="{StaticResource ButtonPill}" />
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding HasJobs, Converter={StaticResource InvBoolToVis}}">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource FontDisplay}"
                    FontSize="48"
                    Foreground="{StaticResource BrushGoldHi}"
                    Effect="{StaticResource ShadowGoldGlowSoft}"
                    Text="✦" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource FontDisplay}"
                    FontSize="20"
                    FontStyle="Italic"
                    Foreground="{StaticResource BrushText1}"
                    Text="No jobs yet" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    Style="{StaticResource TextSecondary}"
                    FontSize="12"
                    TextAlignment="Center"
                    MaxWidth="380"
                    TextWrapping="Wrap"
                    Text="Every Summon Scene logs a row here — queued, running, done, or error. Useful for tracking provider credits + retrying failures." />
            </StackPanel>

            <ScrollViewer
                Padding="32,8,32,32"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasJobs, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Jobs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="16,12"
                                Style="{StaticResource SurfaceCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Status pill  -->
                                    <Border
                                        Grid.Column="0"
                                        Padding="9,4"
                                        VerticalAlignment="Center"
                                        CornerRadius="99">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BrushSurface03}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource BrushLineHairline}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="done">
                                                        <Setter Property="Background" Value="#1F6DBF8C" />
                                                        <Setter Property="BorderBrush" Value="#666DBF8C" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="error">
                                                        <Setter Property="Background" Value="#1FD05A5A" />
                                                        <Setter Property="BorderBrush" Value="#66D05A5A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="cancelled">
                                                        <Setter Property="Background" Value="#1F7D7388" />
                                                        <Setter Property="BorderBrush" Value="#667D7388" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="queued">
                                                        <Setter Property="Background" Value="#1FE0B056" />
                                                        <Setter Property="BorderBrush" Value="#66E0B056" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="running">
                                                        <Setter Property="Background" Value="#1FD4A76A" />
                                                        <Setter Property="BorderBrush" Value="#66D4A76A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="9.5" Style="{StaticResource TextMonoUpper}" Text="{Binding Status}" />
                                    </Border>

                                    <!--  Body  -->
                                    <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                FontFamily="{StaticResource FontUI}"
                                                FontSize="13"
                                                FontWeight="Medium"
                                                Foreground="{StaticResource BrushText1}"
                                                Text="{Binding Provider}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Style="{StaticResource TextMono}"
                                                Foreground="{StaticResource BrushText3}"
                                                Text="{Binding ShortId, StringFormat=#{0}}" />
                                        </Grid>
                                        <TextBlock
                                            Margin="0,3,0,0"
                                            FontSize="11"
                                            Style="{StaticResource TextSecondary}"
                                            Text="{Binding ErrorMessage}"
                                            TextTrimming="CharacterEllipsis"
                                            Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullOrEmpty}}" />
                                        <TextBlock
                                            Margin="0,3,0,0"
                                            FontSize="9.5"
                                            Style="{StaticResource TextMonoUpper}"
                                            Text="{Binding ShotId, StringFormat=SHOT {0}}" />
                                    </StackPanel>

                                    <!--  Right meta  -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="10"
                                            Style="{StaticResource TextMonoGold}"
                                            Text="{Binding DurationLabel}" />
                                        <TextBlock
                                            Margin="0,3,0,0"
                                            HorizontalAlignment="Right"
                                            FontSize="10"
                                            Style="{StaticResource TextMono}"
                                            Foreground="{StaticResource BrushText3}"
                                            Text="{Binding SubmittedAt, StringFormat={}{0:HH:mm:ss}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
