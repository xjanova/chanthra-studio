<UserControl
    x:Class="ChanthraStudio.Views.LibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Background="{StaticResource BrushBgBase}"
    d:DataContext="{d:DesignInstance vm:LibraryViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Floating toast (path copied / delete confirm / errors)  -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="0,18,0,0"
            Padding="14,8"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Panel.ZIndex="50"
            CornerRadius="99"
            Effect="{StaticResource ShadowGoldGlowSoft}"
            Visibility="{Binding ToastMessage, Converter={StaticResource NotNullOrEmpty}, FallbackValue=Collapsed}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource BrushSurface03}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushLineHairline}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ToastKind}" Value="ok">
                            <Setter Property="Background" Value="#1F6DBF8C" />
                            <Setter Property="BorderBrush" Value="#666DBF8C" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastKind}" Value="err">
                            <Setter Property="Background" Value="#1FD05A5A" />
                            <Setter Property="BorderBrush" Value="#66D05A5A" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock
                FontFamily="{StaticResource FontUI}"
                FontSize="11.5"
                Foreground="{StaticResource BrushText1}"
                Text="{Binding ToastMessage}" />
        </Border>

        <!--  Header bar  -->
        <Grid
            Grid.Row="0"
            Margin="32,22,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource TextPanelHeader}" FontSize="22">
                    <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                    <Run Text="Library" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0" Style="{StaticResource TextSecondary}" FontSize="12" Text="{Binding Summary}" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                <!--  Render bar — visible only when something selected  -->
                <StackPanel Orientation="Horizontal" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <Border Padding="10,6" VerticalAlignment="Center" Background="{StaticResource BrushSurface03}" BorderBrush="{StaticResource BrushLineGold}" BorderThickness="1" CornerRadius="99">
                        <TextBlock FontSize="11" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushGoldHi}">
                            <Run Text="{Binding SelectedCount}" /><Run Text=" SELECTED" />
                        </TextBlock>
                    </Border>
                    <Button Margin="8,0,0,0" Command="{Binding ClearSelectionCommand}" Content="Clear" Style="{StaticResource ButtonPill}" />
                    <Button Margin="8,0,0,0" Command="{Binding RenderFilmCommand}" Content="✦  Render film" Style="{StaticResource ButtonPillGold}" />
                    <Border Width="14" />
                </StackPanel>
                <Button Command="{Binding RefreshCommand}" Content="Refresh" Style="{StaticResource ButtonPill}" />
            </StackPanel>
        </Grid>

        <!--  Body  -->
        <Grid Grid.Row="1">
            <!--  Empty state  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding HasClips, Converter={StaticResource InvBoolToVis}}">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource FontDisplay}"
                    FontSize="48"
                    Foreground="{StaticResource BrushGoldHi}"
                    Effect="{StaticResource ShadowGoldGlowSoft}"
                    Text="✦" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource FontDisplay}"
                    FontSize="20"
                    FontStyle="Italic"
                    Foreground="{StaticResource BrushText1}"
                    Text="No clips yet" />
                <TextBlock
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    Style="{StaticResource TextSecondary}"
                    FontSize="12"
                    TextAlignment="Center"
                    MaxWidth="380"
                    TextWrapping="Wrap"
                    Text="Generated images and videos will appear here. Hit ✦ Summon Scene in the Generate workspace to begin." />
            </StackPanel>

            <!--  Clip grid  -->
            <ScrollViewer
                Padding="32,8,32,32"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasClips, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Clips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemHeight="220" ItemWidth="280" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,12,12"
                                Padding="0"
                                Cursor="Hand"
                                Style="{StaticResource SurfaceCard}">
                                <Border.InputBindings>
                                    <MouseBinding
                                        Command="{Binding DataContext.OpenClipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        MouseAction="LeftDoubleClick" />
                                </Border.InputBindings>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem
                                            Command="{Binding DataContext.OpenClipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Header="Open in default viewer" />
                                        <MenuItem
                                            Command="{Binding DataContext.RevealCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Header="Reveal in Explorer" />
                                        <MenuItem
                                            Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Header="Copy path" />
                                        <Separator />
                                        <MenuItem
                                            Command="{Binding DataContext.PostClipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Header="✦ Post…" />
                                        <Separator />
                                        <MenuItem
                                            Command="{Binding DataContext.DeleteClipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Header="Delete clip and file" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!--  Thumb (file image, fallback grey)  -->
                                    <Border Grid.Row="0" CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <Grid>
                                            <Border Background="{StaticResource BrushBgInset}" />
                                            <Image
                                                Stretch="UniformToFill"
                                                Source="{Binding FilePath, IsAsync=True}"
                                                RenderOptions.BitmapScalingMode="HighQuality" />
                                            <!--  Selection checkbox overlay (top-left)  -->
                                            <CheckBox
                                                Margin="10"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                Cursor="Hand">
                                                <CheckBox.Template>
                                                    <ControlTemplate TargetType="CheckBox">
                                                        <Border
                                                            x:Name="bd"
                                                            Width="22"
                                                            Height="22"
                                                            Background="{StaticResource BrushBlackOverlay55}"
                                                            BorderBrush="{StaticResource BrushLineHairline}"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                            <Path
                                                                x:Name="check"
                                                                Width="11"
                                                                Height="11"
                                                                Data="M3 7 L7 11 L13 4"
                                                                Stretch="Uniform"
                                                                Stroke="#FF1A0D05"
                                                                StrokeThickness="2"
                                                                Visibility="Collapsed" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushGoldHi}" />
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrushGold}" />
                                                                <Setter TargetName="check" Property="Visibility" Value="Visible" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrushLineGold}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </CheckBox.Template>
                                            </CheckBox>
                                        </Grid>
                                    </Border>
                                    <!--  Meta footer  -->
                                    <Border
                                        Grid.Row="1"
                                        Padding="12,8"
                                        BorderBrush="{StaticResource BrushLineHairline}"
                                        BorderThickness="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock
                                                    FontFamily="{StaticResource FontUI}"
                                                    FontSize="11.5"
                                                    FontWeight="Medium"
                                                    Foreground="{StaticResource BrushText1}"
                                                    Text="{Binding FileName}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Margin="0,3,0,0"
                                                    FontSize="9.5"
                                                    Style="{StaticResource TextMonoUpper}"
                                                    Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="1"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource BrushSurface03}"
                                                CornerRadius="4">
                                                <TextBlock FontSize="9" Style="{StaticResource TextMonoGold}" Text="{Binding SizeLabel}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
