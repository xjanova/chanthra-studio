<UserControl
    x:Class="ChanthraStudio.Controls.TitleBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:ChanthraStudio.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    Height="38"
    d:DataContext="{d:DesignInstance vm:MainViewModel}"
    d:DesignWidth="1640"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="138" />
        </Grid.ColumnDefinitions>

        <!--  Brand cell  -->
        <StackPanel
            Grid.Column="0"
            Margin="14,0,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <c:BrandMark VerticalAlignment="Center" />
            <TextBlock
                Margin="9,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource TextWordmarkBrand}">
                <Run Text="Chanthra " />
                <Run
                    FontStyle="Italic"
                    Foreground="{StaticResource BrushGoldHi}"
                    Text="Studio" />
            </TextBlock>
        </StackPanel>

        <!--  Tabs  -->
        <ItemsControl
            Grid.Column="1"
            Margin="14,0,0,0"
            VerticalAlignment="Stretch"
            ItemsSource="{Binding OpenTabs}"
            shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,8,2,0">
                        <Border x:Name="tabBg" CornerRadius="8,8,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrushBgBase}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Border
                                    Height="1.5"
                                    VerticalAlignment="Bottom"
                                    Background="{StaticResource BrushActiveTabUnderline}"
                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}" />
                                <Button
                                    Padding="14,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}"
                                    Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <Ellipse
                                            Width="6"
                                            Height="6"
                                            Margin="0,0,8,0"
                                            Fill="{StaticResource BrushGold}"
                                            Visibility="{Binding IsLive, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12.5"
                                            Foreground="{StaticResource BrushText2}"
                                            Style="{StaticResource TextBody}"
                                            Text="{Binding Title}" />
                                        <Button
                                            Width="18"
                                            Height="18"
                                            Margin="10,0,0,0"
                                            Padding="3"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}"
                                            Style="{StaticResource ButtonIcon}">
                                            <Path
                                                Data="{StaticResource IcoClose}"
                                                Stretch="Uniform"
                                                Stroke="{StaticResource BrushText3}"
                                                StrokeThickness="1.4" />
                                        </Button>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  + new tab + search  -->
        <StackPanel
            Grid.Column="2"
            Margin="6,0,12,0"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button
                Width="28"
                Height="28"
                Command="{Binding NewTabCommand}"
                Style="{StaticResource ButtonIcon}"
                ToolTip="New project tab">
                <Path
                    Width="14"
                    Height="14"
                    Data="{StaticResource IcoPlus}"
                    Stretch="Uniform"
                    Stroke="{StaticResource BrushText2}"
                    StrokeThickness="1.4" />
            </Button>
            <Border
                Width="320"
                Height="26"
                Margin="14,0,0,0"
                Background="{StaticResource BrushSurface03}"
                BorderBrush="{StaticResource BrushLineHairline}"
                BorderThickness="1"
                CornerRadius="13">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Path
                        Grid.Column="0"
                        Width="13"
                        Height="13"
                        Data="{StaticResource IcoSearch}"
                        Stretch="Uniform"
                        Stroke="{StaticResource BrushText3}"
                        StrokeThickness="1.5" />
                    <TextBox
                        Grid.Column="1"
                        Padding="8,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource SearchTextBox}"
                        Tag="Search prompts, scenes, models…" />
                    <Border
                        Grid.Column="2"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Background="{StaticResource BrushBgInset}"
                        CornerRadius="4">
                        <TextBlock
                            FontSize="9"
                            Style="{StaticResource TextMonoUpper}"
                            Text="Ctrl K" />
                    </Border>
                </Grid>
            </Border>
        </StackPanel>

        <!--  Window controls  -->
        <StackPanel
            Grid.Column="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button
                x:Name="MinBtn"
                Click="MinBtn_Click"
                Style="{StaticResource ButtonWindowControl}"
                ToolTip="Minimize">
                <Path
                    Width="11"
                    Height="11"
                    Data="{StaticResource IcoMinimize}"
                    Stretch="Uniform"
                    Stroke="{StaticResource BrushText2}"
                    StrokeThickness="1.4" />
            </Button>
            <Button
                x:Name="MaxBtn"
                Click="MaxBtn_Click"
                Style="{StaticResource ButtonWindowControl}"
                ToolTip="Maximize">
                <Path
                    Width="11"
                    Height="11"
                    Data="{StaticResource IcoMaximize}"
                    Fill="Transparent"
                    Stretch="Uniform"
                    Stroke="{StaticResource BrushText2}"
                    StrokeThickness="1.4" />
            </Button>
            <Button
                x:Name="CloseBtn"
                Click="CloseBtn_Click"
                Style="{StaticResource ButtonWindowClose}"
                ToolTip="Close">
                <Path
                    Width="11"
                    Height="11"
                    Data="{StaticResource IcoClose}"
                    Stretch="Uniform"
                    Stroke="{StaticResource BrushText2}"
                    StrokeThickness="1.4" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
