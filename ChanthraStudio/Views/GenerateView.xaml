<UserControl
    x:Class="ChanthraStudio.Views.GenerateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ChanthraStudio.ViewModels"
    d:DataContext="{d:DesignInstance vm:GenerateViewModel}"
    d:DesignHeight="934"
    d:DesignWidth="1576"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <!--  ============== COMPOSER (left) ==============  -->
        <Border
            Grid.Column="0"
            Background="{StaticResource BrushBgBase}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <!--  Header  -->
                <Grid Margin="18,16,18,12" DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource TextPanelHeader}">
                        <Run Foreground="{StaticResource BrushGold}" Text="✦ " />
                        <Run Text="Composer" />
                    </TextBlock>
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Style="{StaticResource TextMonoUpper}"
                        Text="{Binding SceneLabel}" />
                </Grid>

                <!--  Footer: Generate CTA  -->
                <Border
                    Margin="18,12,18,18"
                    BorderBrush="{StaticResource BrushLineGold}"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom">
                    <Button
                        Margin="0,12,0,0"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding SummonSceneCommand}"
                        Style="{StaticResource ButtonSummonCta}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource TextSummonCta}"
                                Text="✦ Summon Scene" />
                            <Border
                                Grid.Column="1"
                                Margin="0,0,12,0"
                                Padding="6,2"
                                Background="#33000000"
                                CornerRadius="4">
                                <TextBlock
                                    FontFamily="{StaticResource FontMono}"
                                    FontSize="10"
                                    Foreground="#FF1A0D05"
                                    Text="{Binding Credits}" />
                            </Border>
                        </Grid>
                    </Button>
                </Border>

                <!--  Scrollable body  -->
                <ScrollViewer
                    Margin="18,0,12,0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!--  3a. Prompt box  -->
                        <Border Background="{StaticResource BrushBgSurface}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="10">
                            <DockPanel>
                                <Border
                                    BorderBrush="{StaticResource BrushLineHairline}"
                                    BorderThickness="0,1,0,0"
                                    DockPanel.Dock="Bottom">
                                    <Grid Margin="10,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border
                                                Margin="0,0,6,0"
                                                Padding="6,3"
                                                Background="#1FD4A76A"
                                                BorderBrush="{StaticResource BrushLineGold}"
                                                BorderThickness="1"
                                                CornerRadius="99">
                                                <TextBlock
                                                    FontSize="9"
                                                    Foreground="{StaticResource BrushGoldHi}"
                                                    Style="{StaticResource TextMonoUpper}"
                                                    Text="cinematic" />
                                            </Border>
                                            <Border
                                                Margin="0,0,6,0"
                                                Padding="6,3"
                                                Background="#1FB03346"
                                                BorderBrush="{StaticResource BrushLineCrimson}"
                                                BorderThickness="1"
                                                CornerRadius="99">
                                                <TextBlock
                                                    FontSize="9"
                                                    Foreground="#FFE89AA5"
                                                    Style="{StaticResource TextMonoUpper}"
                                                    Text="silk" />
                                            </Border>
                                            <Border
                                                Padding="6,3"
                                                Background="#0FFFFFFF"
                                                BorderBrush="{StaticResource BrushLineHairline}"
                                                BorderThickness="1"
                                                CornerRadius="99">
                                                <TextBlock
                                                    FontSize="9"
                                                    Style="{StaticResource TextMonoUpper}"
                                                    Text="thai" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button
                                                Width="24"
                                                Height="24"
                                                Style="{StaticResource ButtonIcon}"
                                                ToolTip="Attach">
                                                <Path
                                                    Width="13"
                                                    Height="13"
                                                    Data="{StaticResource IcoPaperclip}"
                                                    Stretch="Uniform"
                                                    Stroke="{StaticResource BrushText3}"
                                                    StrokeThickness="1.4" />
                                            </Button>
                                            <Button
                                                Width="24"
                                                Height="24"
                                                Style="{StaticResource ButtonIcon}"
                                                ToolTip="Add image">
                                                <Path
                                                    Width="13"
                                                    Height="13"
                                                    Data="{StaticResource IcoImage}"
                                                    Fill="Transparent"
                                                    Stretch="Uniform"
                                                    Stroke="{StaticResource BrushText3}"
                                                    StrokeThickness="1.4" />
                                            </Button>
                                            <Button
                                                Width="24"
                                                Height="24"
                                                Command="{Binding EnhancePromptCommand}"
                                                Style="{StaticResource ButtonIcon}"
                                                ToolTip="✦ Enhance prompt via active LLM">
                                                <Path
                                                    Width="13"
                                                    Height="13"
                                                    Data="{StaticResource IcoWand}"
                                                    Stretch="Uniform"
                                                    Stroke="{StaticResource BrushGoldHi}"
                                                    StrokeThickness="1.4" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBox
                                    MinHeight="92"
                                    Style="{StaticResource PromptTextBox}"
                                    Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </Border>

                        <!--  3b. Visual lineage  -->
                        <TextBlock
                            Margin="0,18,0,8"
                            Style="{StaticResource TextSectionDivider}"
                            Text="VISUAL LINEAGE" />
                        <ItemsControl ItemsSource="{Binding StylePresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="3"
                                        BorderBrush="{StaticResource BrushLineHairline}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid>
                                            <Border CornerRadius="6" ClipToBounds="True">
                                                <Border.Background>
                                                    <ImageBrush
                                                        ImageSource="{Binding ThumbPath}"
                                                        Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" CornerRadius="0,0,6,6">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Offset="0" Color="#00000000" />
                                                        <GradientStop Offset="1" Color="#D9000000" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock
                                                    Margin="6,12,6,4"
                                                    HorizontalAlignment="Center"
                                                    FontFamily="{StaticResource FontDisplay}"
                                                    FontSize="10.5"
                                                    FontStyle="Italic"
                                                    Foreground="{StaticResource BrushText1}"
                                                    Text="{Binding Name}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  3c. Engine / workflow picker (real ComboBox, styled to match)  -->
                        <Border
                            Margin="0,18,0,0"
                            Background="{StaticResource BrushBgSurface}"
                            BorderBrush="{StaticResource BrushLineHairline}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    Width="30"
                                    Height="30"
                                    Background="{StaticResource BrushEngineBadge}"
                                    BorderBrush="{StaticResource BrushLineGold}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontDisplay}"
                                        FontSize="13"
                                        FontStyle="Italic"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource BrushGoldHi}"
                                        Text="✦" />
                                </Border>
                                <ComboBox
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource BrushText1}"
                                    FontFamily="{StaticResource FontUI}"
                                    FontSize="12.5"
                                    ItemsSource="{Binding Workflows}"
                                    SelectedItem="{Binding ActiveWorkflow, Mode=TwoWay}"
                                    Cursor="Hand">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock
                                                    FontFamily="{StaticResource FontUI}"
                                                    FontSize="12.5"
                                                    Foreground="{StaticResource BrushText1}"
                                                    Text="{Binding DisplayName}" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    Style="{StaticResource TextMonoUpper}"
                                                    Text="{Binding Spec}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button
                                    Grid.Column="2"
                                    Width="22"
                                    Height="22"
                                    Command="{Binding RefreshWorkflowsCommand}"
                                    Style="{StaticResource ButtonIcon}"
                                    ToolTip="Refresh workflows folder">
                                    <Path
                                        Width="11"
                                        Height="11"
                                        Data="M3 12 A9 9 0 1 1 12 21 M12 21 L8 17 M12 21 L8 25"
                                        Stretch="Uniform"
                                        Stroke="{StaticResource BrushText3}"
                                        StrokeThickness="1.4" />
                                </Button>
                            </Grid>
                        </Border>

                        <!--  3c-bis. Reference image — drop or browse, used by img2img / WAN i2v workflows  -->
                        <Border
                            Margin="0,18,0,0"
                            Background="{StaticResource BrushBgSurface}"
                            BorderBrush="{StaticResource BrushLineHairline}"
                            BorderThickness="1"
                            CornerRadius="10"
                            AllowDrop="True"
                            Drop="ReferenceImage_Drop"
                            DragOver="ReferenceImage_DragOver"
                            MouseLeftButtonUp="ReferenceImage_BrowseClick"
                            Cursor="Hand">
                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Thumbnail or placeholder  -->
                                <Border
                                    Grid.Column="0"
                                    Width="48"
                                    Height="48"
                                    Background="{StaticResource BrushBgInset}"
                                    BorderBrush="{StaticResource BrushLineHairline}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    ClipToBounds="True">
                                    <Grid>
                                        <Path
                                            Width="22"
                                            Height="22"
                                            Data="{StaticResource IcoImage}"
                                            Stretch="Uniform"
                                            Stroke="{StaticResource BrushText3}"
                                            StrokeThickness="1.4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                        <Image
                                            Source="{Binding ReferenceImagePath, Converter={StaticResource ClipPathToImage}}"
                                            Stretch="UniformToFill" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                    <TextBlock
                                        Style="{StaticResource TextMonoUpper}"
                                        Text="REFERENCE IMAGE" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{StaticResource FontMono}"
                                        FontSize="11"
                                        Foreground="{StaticResource BrushText1}"
                                        Text="{Binding ReferenceImageFileName}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Button
                                    Grid.Column="2"
                                    Width="22"
                                    Height="22"
                                    Command="{Binding ClearReferenceImageCommand}"
                                    Style="{StaticResource ButtonIcon}"
                                    Visibility="{Binding HasReferenceImage, Converter={StaticResource BoolToVis}}"
                                    ToolTip="Clear reference image">
                                    <Path
                                        Width="9"
                                        Height="9"
                                        Data="{StaticResource IcoClose}"
                                        Stretch="Uniform"
                                        Stroke="{StaticResource BrushText3}"
                                        StrokeThickness="1.4" />
                                </Button>
                            </Grid>
                        </Border>

                        <!--  3d. Parameters  -->
                        <Border
                            Margin="0,18,0,0"
                            Background="{StaticResource BrushBgSurface}"
                            BorderBrush="{StaticResource BrushLineHairline}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel>
                                <!--  Aspect  -->
                                <Grid Margin="13,10" Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Aspect" />
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                        <RadioButton GroupName="aspect" Margin="0,0,4,0" Content="9:16" Style="{StaticResource ChipRadio}" />
                                        <RadioButton GroupName="aspect" Margin="0,0,4,0" Content="1:1" Style="{StaticResource ChipRadio}" />
                                        <RadioButton GroupName="aspect" Margin="0,0,4,0" Content="16:9" IsChecked="True" Style="{StaticResource ChipRadio}" />
                                        <RadioButton GroupName="aspect" Content="21:9" Style="{StaticResource ChipRadio}" />
                                    </StackPanel>
                                </Grid>
                                <Border BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="0,1,0,0" />

                                <!--  Duration  -->
                                <Grid Margin="13,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Duration" />
                                    <Slider
                                        Grid.Column="1"
                                        Margin="6,0"
                                        Maximum="20"
                                        Minimum="1"
                                        Style="{StaticResource GoldSlider}"
                                        Value="{Binding DurationSec}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" Text="{Binding DurationSec, StringFormat={}{0:F1}s}" />
                                </Grid>
                                <Border BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="0,1,0,0" />

                                <!--  Motion  -->
                                <Grid Margin="13,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Motion" />
                                    <Slider
                                        Grid.Column="1"
                                        Margin="6,0"
                                        Maximum="1"
                                        Minimum="0"
                                        Style="{StaticResource GoldSlider}"
                                        Value="{Binding Motion}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" Text="{Binding Motion, StringFormat={}{0:F2}}" />
                                </Grid>
                                <Border BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="0,1,0,0" />

                                <!--  Seed  -->
                                <Grid Margin="13,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Seed" />
                                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource TextMonoGold}" Text="{Binding SeedLabel}" />
                                    <Button Grid.Column="2" Width="22" Height="22" Margin="6,0,0,0" Style="{StaticResource ButtonIcon}" ToolTip="Shuffle seed">
                                        <Path Width="11" Height="11" Data="{StaticResource IcoShuffle}" Stretch="Uniform" Stroke="{StaticResource BrushText3}" StrokeThickness="1.4" />
                                    </Button>
                                </Grid>
                                <Border BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="0,1,0,0" />

                                <!--  HD upscale 4K  -->
                                <Grid Margin="13,10" Height="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="HD Upscale 4K" />
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding Hd4k}" Style="{StaticResource ToggleSwitch}" />
                                </Grid>
                                <Border BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="0,1,0,0" />

                                <!--  Native audio  -->
                                <Grid Margin="13,10" Height="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextLabel}" Text="Native audio" />
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding NativeAudio}" Style="{StaticResource ToggleSwitch}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!--  3e. Camera language  -->
                        <TextBlock
                            Margin="0,18,0,8"
                            Style="{StaticResource TextSectionDivider}"
                            Text="CAMERA LANGUAGE" />
                        <UniformGrid Columns="3" Rows="2">
                            <RadioButton GroupName="camera" Margin="0,0,4,4" Style="{StaticResource ChipRadio}" Height="58">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,0,4"
                                        BorderBrush="{StaticResource BrushText3}"
                                        BorderThickness="1.4"
                                        CornerRadius="3" />
                                    <TextBlock Style="{StaticResource TextMonoUpper}" Text="LOCKED" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="camera" Margin="0,0,4,4" Style="{StaticResource ChipRadio}" Height="58">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Margin="0,0,0,4" Width="22" Height="22" Data="M4 12 H20 M16 8 L20 12 L16 16 M8 8 L4 12 L8 16" Stretch="Uniform" Stroke="{StaticResource BrushText3}" StrokeThickness="1.4" />
                                    <TextBlock Style="{StaticResource TextMonoUpper}" Text="PAN" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="camera" Margin="0,0,0,4" Style="{StaticResource ChipRadio}" Height="58">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Margin="0,0,0,4" Width="22" Height="22" Data="M12 4 V20 M8 16 L12 20 L16 16 M8 8 L12 4 L16 8" Stretch="Uniform" Stroke="{StaticResource BrushText3}" StrokeThickness="1.4" />
                                    <TextBlock Style="{StaticResource TextMonoUpper}" Text="TILT" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="camera" Margin="0,0,4,0" IsChecked="True" Style="{StaticResource ChipRadio}" Height="58">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Margin="0,0,0,4" Width="22" Height="22" Data="M4 4 L20 4 L20 20 L4 20 Z M9 9 L15 9 L15 15 L9 15 Z" Stretch="Uniform" Stroke="{StaticResource BrushGoldHi}" StrokeThickness="1.4" />
                                    <TextBlock FontSize="9" Foreground="{StaticResource BrushGoldHi}" Style="{StaticResource TextMonoUpper}" Text="PUSH" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="camera" Margin="0,0,4,0" Style="{StaticResource ChipRadio}" Height="58">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Margin="0,0,0,4" Width="22" Height="22" Data="M12 4 A8 8 0 1 1 12 20 A8 8 0 1 1 12 4 M12 4 V8 M16 8 L12 4" Stretch="Uniform" Stroke="{StaticResource BrushText3}" StrokeThickness="1.4" />
                                    <TextBlock Style="{StaticResource TextMonoUpper}" Text="ORBIT" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="camera" Style="{StaticResource ChipRadio}" Height="58">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Margin="0,0,0,4" Width="22" Height="22" Data="M3 12 H21 M9 6 L21 12 L9 18 Z" Stretch="Uniform" Stroke="{StaticResource BrushText3}" StrokeThickness="1.4" />
                                    <TextBlock Style="{StaticResource TextMonoUpper}" Text="DOLLY" />
                                </StackPanel>
                            </RadioButton>
                        </UniformGrid>

                        <Border Height="14" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!--  ============== STAGE (center) ==============  -->
        <Grid Grid.Column="1" Background="{StaticResource BrushBgBase}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!--  Floating toast (sits above everything in this column)  -->
            <Border
                Grid.Row="0"
                Grid.RowSpan="3"
                Margin="0,18,0,0"
                Padding="14,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Panel.ZIndex="50"
                CornerRadius="99"
                Effect="{StaticResource ShadowGoldGlowSoft}"
                Visibility="{Binding ToastMessage, Converter={StaticResource NotNullOrEmpty}, FallbackValue=Collapsed}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BrushSurface03}" />
                        <Setter Property="BorderBrush" Value="{StaticResource BrushLineHairline}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastKind}" Value="ok">
                                <Setter Property="Background" Value="#1F6DBF8C" />
                                <Setter Property="BorderBrush" Value="#666DBF8C" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastKind}" Value="warn">
                                <Setter Property="Background" Value="#1FE0B056" />
                                <Setter Property="BorderBrush" Value="#66E0B056" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastKind}" Value="err">
                                <Setter Property="Background" Value="#1FD05A5A" />
                                <Setter Property="BorderBrush" Value="#66D05A5A" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastKind}" Value="info">
                                <Setter Property="Background" Value="#1FD4A76A" />
                                <Setter Property="BorderBrush" Value="#66D4A76A" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock
                    FontFamily="{StaticResource FontUI}"
                    FontSize="11.5"
                    Foreground="{StaticResource BrushText1}"
                    Text="{Binding ToastMessage}" />
            </Border>

            <!--  Stage bar  -->
            <Grid Grid.Row="0" Margin="22,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource TextSecondary}" FontSize="12.5" Text="{Binding Breadcrumb}" />
                    <Border
                        Margin="14,0,0,0"
                        Padding="9,4"
                        Background="#1FD4A76A"
                        BorderBrush="{StaticResource BrushLineGold}"
                        BorderThickness="1"
                        CornerRadius="99"
                        Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                Width="5"
                                Height="5"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource PulsingGoldDot}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource BrushGoldHi}"
                                Style="{StaticResource TextMonoUpper}"
                                Text="{Binding GeneratingDuration}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Content="History" Style="{StaticResource ButtonPill}" />
                    <Button Margin="0,0,8,0" Content="Share" Style="{StaticResource ButtonPill}" />
                    <Button Margin="0,0,8,0" Content="Export" Style="{StaticResource ButtonPill}" />
                    <Button Content="✦  Render film" Style="{StaticResource ButtonPillGold}" />
                </StackPanel>
            </Grid>

            <!--  Canvas  -->
            <Grid Grid.Row="1" Margin="24,0,24,0">
                <Border CornerRadius="10" ClipToBounds="True">
                    <Border.Background>
                        <DrawingBrush
                            TileMode="Tile"
                            Viewport="0,0,32,32"
                            ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="{StaticResource BrushBgInset}">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,32,32" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#0AD4A76A" Thickness="1" />
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="32,0" EndPoint="32,32" />
                                                <LineGeometry StartPoint="0,32" EndPoint="32,32" />
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Border.Background>
                </Border>

                <!--  16:9 framed art  -->
                <Viewbox MaxHeight="540" Margin="40">
                    <Border
                        Width="1280"
                        Height="720"
                        BorderBrush="#2ED4A76A"
                        BorderThickness="1"
                        CornerRadius="6"
                        ClipToBounds="True"
                        Effect="{StaticResource ShadowCanvas}">
                        <Grid>
                            <!--  poster frame  -->
                            <Image Source="/Assets/Brand/empress-wide.png" Stretch="UniformToFill" />

                            <!--  L-corner guides  -->
                            <Border
                                Width="36"
                                Height="36"
                                Margin="18"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                BorderBrush="{StaticResource BrushGold}"
                                BorderThickness="2,2,0,0" />
                            <Border
                                Width="36"
                                Height="36"
                                Margin="18"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                BorderBrush="{StaticResource BrushGold}"
                                BorderThickness="0,2,2,0" />
                            <Border
                                Width="36"
                                Height="36"
                                Margin="18"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                BorderBrush="{StaticResource BrushGold}"
                                BorderThickness="2,0,0,2" />
                            <Border
                                Width="36"
                                Height="36"
                                Margin="18"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                BorderBrush="{StaticResource BrushGold}"
                                BorderThickness="0,0,2,2" />

                            <!--  Top-left meta pills  -->
                            <StackPanel
                                Margin="22"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Orientation="Horizontal">
                                <Border
                                    Margin="0,0,6,0"
                                    Padding="8,4"
                                    Background="{StaticResource BrushBlackOverlay55}"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="10"
                                        Style="{StaticResource TextMonoUpper}"
                                        Text="{Binding ShotMetaShot}" />
                                </Border>
                                <Border
                                    Margin="0,0,6,0"
                                    Padding="8,4"
                                    Background="{StaticResource BrushBlackOverlay55}"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="10"
                                        Style="{StaticResource TextMonoUpper}"
                                        Text="{Binding ShotMetaFrame}" />
                                </Border>
                                <Border
                                    Margin="0,0,6,0"
                                    Padding="8,4"
                                    Background="{StaticResource BrushBlackOverlay55}"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="10"
                                        Style="{StaticResource TextMonoUpper}"
                                        Text="{Binding ShotMetaLens}" />
                                </Border>
                                <Border
                                    Padding="8,4"
                                    Background="{StaticResource BrushBlackOverlay55}"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="10"
                                        Style="{StaticResource TextMonoUpper}"
                                        Text="{Binding ShotMetaSeed}" />
                                </Border>
                            </StackPanel>

                            <!--  Top-right watermark  -->
                            <TextBlock
                                Margin="22"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Style="{StaticResource TextWatermark}"
                                Text="✦ Chanthra preview" />

                            <!--  Playback bar  -->
                            <Border
                                Height="56"
                                Margin="14,0,14,14"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource BrushBlackOverlay65}"
                                BorderBrush="{StaticResource BrushLineHairline}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <Grid Margin="14,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                            Width="36"
                                            Height="32"
                                            Style="{StaticResource ButtonSummonCta}">
                                            <Path
                                                Width="14"
                                                Height="14"
                                                Data="{StaticResource IcoPlay}"
                                                Fill="#FF1A0D05"
                                                Stretch="Uniform" />
                                        </Button>
                                    </StackPanel>
                                    <Grid Grid.Column="1" Margin="14,0">
                                        <Border
                                            Height="4"
                                            VerticalAlignment="Center"
                                            Background="#1AFFFFFF"
                                            CornerRadius="2" />
                                        <Border
                                            Width="380"
                                            Height="4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource BrushSliderFill}"
                                            CornerRadius="2" />
                                        <Canvas VerticalAlignment="Center">
                                            <Rectangle
                                                Canvas.Left="84"
                                                Canvas.Top="-4"
                                                Width="8"
                                                Height="8"
                                                Fill="{StaticResource BrushGoldHi}"
                                                RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="45" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle
                                                Canvas.Left="266"
                                                Canvas.Top="-4"
                                                Width="8"
                                                Height="8"
                                                Fill="{StaticResource BrushGoldHi}"
                                                RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="45" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle
                                                Canvas.Left="532"
                                                Canvas.Top="-4"
                                                Width="8"
                                                Height="8"
                                                Fill="{StaticResource BrushGoldHi}"
                                                RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="45" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Canvas>
                                    </Grid>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,12,0"
                                            FontSize="10"
                                            Foreground="{StaticResource BrushText2}"
                                            Style="{StaticResource TextMono}"
                                            Text="00:14 / 00:32" />
                                        <Button Width="28" Height="28" Style="{StaticResource ButtonIcon}">
                                            <Path
                                                Width="13"
                                                Height="13"
                                                Data="{StaticResource IcoVolume}"
                                                Fill="Transparent"
                                                Stretch="Uniform"
                                                Stroke="{StaticResource BrushText2}"
                                                StrokeThickness="1.4" />
                                        </Button>
                                        <Button Width="28" Height="28" Style="{StaticResource ButtonIcon}">
                                            <Path
                                                Width="13"
                                                Height="13"
                                                Data="{StaticResource IcoFullscreen}"
                                                Stretch="Uniform"
                                                Stroke="{StaticResource BrushText2}"
                                                StrokeThickness="1.4" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Viewbox>
            </Grid>

            <!--  Timeline  -->
            <Border
                Grid.Row="2"
                MinHeight="170"
                Background="{StaticResource BrushBlackOverlay35}"
                BorderBrush="{StaticResource BrushLineHairline}"
                BorderThickness="0,1,0,0">
                <DockPanel>
                    <Grid Margin="22,12,22,8" DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource TextSectionDivider}" Text="TIMELINE · 32 FPS · DCI 1080" />
                        <UniformGrid Grid.Column="2" Columns="5" Width="420">
                            <TextBlock HorizontalAlignment="Left" Style="{StaticResource TextMonoUpper}" Text="00:00" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource TextMonoUpper}" Text="00:08" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource TextMonoUpper}" Text="00:16" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource TextMonoUpper}" Text="00:24" />
                            <TextBlock HorizontalAlignment="Right" Style="{StaticResource TextMonoUpper}" Text="00:32" />
                        </UniformGrid>
                    </Grid>

                    <StackPanel Margin="22,0,22,12">
                        <!--  Video track  -->
                        <Grid Margin="0,0,0,4" Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextMonoUpper}" Text="VIDEO" />
                            <Border Grid.Column="1" Background="#05FFFFFF" CornerRadius="4">
                                <UniformGrid Columns="4">
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="{StaticResource ColorCrimson}" />
                                                <GradientStop Offset="1" Color="{StaticResource ColorCrimsonDeep}" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Margin="8,0" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource BrushText1}" Style="{StaticResource TextMono}" Text="Throne reveal" />
                                    </Border>
                                    <Border Margin="2" Background="{StaticResource BrushClipPlum}" CornerRadius="4">
                                        <TextBlock Margin="8,0" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource BrushText1}" Style="{StaticResource TextMono}" Text="Veil drop" />
                                    </Border>
                                    <Border Margin="2" Background="{StaticResource BrushClipAmber}" CornerRadius="4">
                                        <TextBlock Margin="8,0" VerticalAlignment="Center" FontSize="10" Foreground="#FF1A0D05" Style="{StaticResource TextMono}" Text="Lotus ascent" />
                                    </Border>
                                    <Border Margin="2" Background="{StaticResource BrushClipPlum}" CornerRadius="4">
                                        <TextBlock Margin="8,0" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource BrushText1}" Style="{StaticResource TextMono}" Text="Halo close" />
                                    </Border>
                                </UniformGrid>
                            </Border>
                        </Grid>

                        <!--  Score track  -->
                        <Grid Margin="0,0,0,4" Height="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextMonoUpper}" Text="SCORE" />
                            <Border Grid.Column="1" Background="#0F4A2E6A" BorderBrush="#33B8A5D0" BorderThickness="1" CornerRadius="4">
                                <Path
                                    Margin="6,4"
                                    Stretch="Fill"
                                    Stroke="{StaticResource BrushMoon}"
                                    StrokeThickness="1.2"
                                    Opacity="0.55"
                                    Data="M0,15 C 30,5 60,25 90,15 S 150,5 180,15 S 240,25 270,15 S 330,5 360,15 S 420,25 450,15 S 510,5 540,15 S 600,25 630,15 S 690,5 720,15 S 780,25 810,15 S 870,5 900,15 S 960,25 990,15" />
                            </Border>
                        </Grid>

                        <!--  Caption track  -->
                        <Grid Height="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource TextMonoUpper}" Text="CAPTION" />
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Margin="2" Padding="8,4" Background="#1F6C5E85" BorderBrush="#33B8A5D0" BorderThickness="1" CornerRadius="4">
                                    <TextBlock VerticalAlignment="Center" FontFamily="{StaticResource FontThai}" FontStyle="Italic" FontSize="11" Foreground="{StaticResource BrushMoon}" Text="จันทรา" />
                                </Border>
                                <Border Grid.Column="2" Margin="2" Padding="8,4" Background="#1F6C5E85" BorderBrush="#33B8A5D0" BorderThickness="1" CornerRadius="4">
                                    <TextBlock VerticalAlignment="Center" FontFamily="{StaticResource FontDisplay}" FontStyle="Italic" FontSize="11" Foreground="{StaticResource BrushMoon}" Text="the moon rises" />
                                </Border>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!--  ============== ASIDE (right) ==============  -->
        <Border
            Grid.Column="2"
            Background="{StaticResource BrushBgBase}"
            BorderBrush="{StaticResource BrushLineHairline}"
            BorderThickness="1,0,0,0">
            <DockPanel LastChildFill="True">

                <!--  Tabs  -->
                <Grid Margin="18,16,18,0" DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="{StaticResource BrushGold}" BorderThickness="0,0,0,1.5" Padding="0,4,0,8">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource TextBody}" FontSize="12" Text="Storyboard " />
                            <Border Padding="6,2" Background="#1FD4A76A" CornerRadius="99">
                                <TextBlock FontSize="9" Foreground="{StaticResource BrushGoldHi}" Style="{StaticResource TextMonoUpper}" Text="12" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="0,4,0,8">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource BrushText3}" Style="{StaticResource TextBody}" FontSize="12" Text="Queue " />
                            <Border Padding="6,2" Background="{StaticResource BrushSurface03}" CornerRadius="99">
                                <TextBlock FontSize="9" Style="{StaticResource TextMonoUpper}" Text="3" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="0,4,0,8">
                        <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource BrushText3}" Style="{StaticResource TextBody}" FontSize="12" Text="Assets" />
                    </Border>
                </Grid>

                <ScrollViewer Margin="18,12,12,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Storyboard}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,12"
                                    BorderBrush="{StaticResource BrushLineHairline}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Cursor="Hand">
                                    <StackPanel>
                                        <Grid Height="172">
                                            <Border CornerRadius="10,10,0,0" ClipToBounds="True">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ThumbUrl}" Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                            <Border Margin="10" Padding="6,3" HorizontalAlignment="Left" VerticalAlignment="Top" Background="{StaticResource BrushBlackOverlay55}" CornerRadius="4">
                                                <TextBlock FontSize="9" Style="{StaticResource TextMonoUpper}" Text="{Binding Number, StringFormat=SHOT {0}}" />
                                            </Border>
                                            <Ellipse
                                                Width="7"
                                                Height="7"
                                                Margin="10"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Effect="{StaticResource ShadowGoldGlowSoft}"
                                                Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                            <Border Margin="10" Padding="6,3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="{StaticResource BrushBlackOverlay55}" CornerRadius="4">
                                                <TextBlock FontSize="9" Style="{StaticResource TextMonoUpper}" Foreground="{StaticResource BrushGoldHi}" Text="{Binding DurationLabel}" />
                                            </Border>
                                            <!--  generation progress bar  -->
                                            <Border Height="2" VerticalAlignment="Bottom" Background="#22FFFFFF">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Generating">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource BrushSliderFill}"
                                                    Effect="{StaticResource ShadowGoldGlowSoft}"
                                                    Width="{Binding Progress, Converter={StaticResource PercentToWidth}, ConverterParameter=320}" />
                                            </Border>
                                        </Grid>
                                        <StackPanel Margin="12,10,12,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Style="{StaticResource TextBody}" FontSize="12.5" FontWeight="Medium" Text="{Binding Title}" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource TextMono}" Text="{Binding Id, StringFormat=#28{0}}" />
                                            </Grid>
                                            <TextBlock Margin="0,4,0,8" MaxHeight="36" Style="{StaticResource TextSecondary}" FontSize="11.5" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Text="{Binding Description}" />
                                            <ItemsControl ItemsSource="{Binding Tags}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,4,0" Padding="6,2" Background="{StaticResource BrushSurface03}" BorderBrush="{StaticResource BrushLineHairline}" BorderThickness="1" CornerRadius="99">
                                                            <TextBlock FontSize="9" Style="{StaticResource TextMonoUpper}" Text="{Binding}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
